---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Panopticon — A sci-fi prison webcomic. You are always being watched.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | PANOPTICON`} />
    <meta property="og:description" content={description} />
    <title>{title} | PANOPTICON</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Electrolize&family=Exo+2:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Zen+Dots&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-p-root text-p-text font-ui antialiased">
    <Header />
    <div class="border-y border-p-accent/15 bg-p-canvas py-1 overflow-hidden">
      <div class="flex gap-12 animate-[scroll_25s_linear_infinite] whitespace-nowrap">
        <span class="font-ui text-p-teal text-xs tracking-widest animate-pulse-teal-text">⊗&nbsp;CLASSIFIED&nbsp;⊗&nbsp;ALL MOVEMENT LOGGED&nbsp;⊗&nbsp;FACILITY SECURITY LEVEL: MAXIMUM&nbsp;⊗&nbsp;DO NOT DISCUSS ESCAPE ROUTES&nbsp;&nbsp;&nbsp;</span>
        <span class="font-ui text-p-teal text-xs tracking-widest animate-pulse-teal-text">⊗&nbsp;CLASSIFIED&nbsp;⊗&nbsp;ALL MOVEMENT LOGGED&nbsp;⊗&nbsp;FACILITY SECURITY LEVEL: MAXIMUM&nbsp;⊗&nbsp;DO NOT DISCUSS ESCAPE ROUTES&nbsp;&nbsp;&nbsp;</span>
        <span class="font-ui text-p-teal text-xs tracking-widest animate-pulse-teal-text">⊗&nbsp;CLASSIFIED&nbsp;⊗&nbsp;ALL MOVEMENT LOGGED&nbsp;⊗&nbsp;FACILITY SECURITY LEVEL: MAXIMUM&nbsp;⊗&nbsp;DO NOT DISCUSS ESCAPE ROUTES&nbsp;&nbsp;&nbsp;</span>
        <span class="font-ui text-p-teal text-xs tracking-widest animate-pulse-teal-text">⊗&nbsp;CLASSIFIED&nbsp;⊗&nbsp;ALL MOVEMENT LOGGED&nbsp;⊗&nbsp;FACILITY SECURITY LEVEL: MAXIMUM&nbsp;⊗&nbsp;DO NOT DISCUSS ESCAPE ROUTES&nbsp;&nbsp;&nbsp;</span>
      </div>
    </div>
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
