---
const browseLinks = [
  { href: '/',           label: 'HOME' },
  { href: '/read',       label: 'READ' },
  { href: '/about',      label: 'ABOUT' },
];
const actionLinks = [
  { href: '/avatar',     label: 'CREATE AN AVATAR', storeKey: 'panopticon_inmate_name', color: 'teal' },
  { href: '/scan',       label: 'SCAN',             storeKey: 'panopticon_intake_complete', color: 'teal' },
];
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-p-canvas/95 backdrop-blur border-b border-p-accent/20">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">

    <!-- Left: Logo + monitoring -->
    <div class="flex flex-col items-start">
      <a href="/" class="flex items-center gap-3 group">
        <img src="/images/panopticon-title.png" alt="PANOPTICON" class="h-8 w-auto opacity-90 group-hover:opacity-100 transition-opacity" />
      </a>
      <div class="hidden md:flex items-center gap-1.5 -mt-0.5">
        <span class="w-1.5 h-1.5 rounded-full bg-p-teal animate-pulse"></span>
        <span class="font-ui text-p-dim text-[9px] tracking-widest">MONITORING ACTIVE</span>
      </div>
    </div>

    <!-- Center: Nav (two-tier split) -->
    <nav class="hidden md:flex items-center gap-0">
      <!-- Browse group -->
      {browseLinks.map(link => {
        const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
        return (
          <a href={link.href} class:list={[
            'px-3 py-2 text-xs font-display tracking-widest transition-all duration-200 text-center leading-tight',
            isActive ? 'text-p-accent border-b-2 border-p-accent' : 'text-p-dim hover:text-p-accent/80',
          ]}>
            {link.label}
          </a>
        );
      })}

      <!-- Divider -->
      <span class="mx-2 h-5 w-px bg-p-dim/30"></span>

      <!-- Action group (with progress dots) -->
      {actionLinks.map(link => {
        const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
        return (
          <a href={link.href} data-store-key={link.storeKey} class:list={[
            'nav-action-link px-3 py-2 text-xs font-display tracking-widest transition-all duration-200 text-center leading-tight flex items-center gap-1.5',
            isActive ? 'text-p-teal border-b-2 border-p-teal' : 'text-p-teal/60 hover:text-p-teal',
          ]}>
            <span class="nav-dot w-1.5 h-1.5 rounded-full border border-p-dim/40 flex-shrink-0" data-store-key={link.storeKey}></span>
            {link.label}
          </a>
        );
      })}

      <!-- Classified nav link (hidden until unlocked) -->
      <a id="nav-classified" href="/unlocked" class="hidden px-3 py-2 text-xs font-display tracking-widest transition-all duration-200 text-center leading-tight flex items-center gap-1.5 text-p-unlock/70 hover:text-p-unlock border-b-2 border-transparent" style="animation: nav-unlock-pulse 2.5s ease-in-out infinite;">
        <span class="nav-dot w-1.5 h-1.5 rounded-full border border-p-dim/40 flex-shrink-0" id="nav-dot-classified"></span>
        CLASSIFIED
      </a>
    </nav>

    <!-- Right: Avatar thumbnail (hidden until unlocked) -->
    <div id="header-avatar-wrap" class="hidden items-center gap-3 cursor-pointer relative" role="button" tabindex="0">
      <div class="flex flex-col items-end">
        <span id="header-avatar-name" class="font-display text-xs tracking-widest text-p-unlock"></span>
        <span id="header-avatar-id" class="font-ui text-[10px] tracking-widest text-p-dim"></span>
      </div>
      <div class="relative">
        <img id="header-avatar-img" src="" alt="Inmate avatar" class="w-12 h-12 border-2 border-p-unlock/60 object-cover hover:border-p-unlock transition-all" style="animation: avatar-thumb-glow 2.5s ease-in-out infinite;" />
        <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-p-teal border-2 border-p-canvas"></div>
      </div>

      <!-- Inmate info dropdown panel -->
      <div id="inmate-panel" class="hidden absolute top-full right-0 mt-2 w-72 bg-p-panel border border-p-unlock/40 z-[100] shadow-2xl" style="box-shadow: 0 4px 30px rgba(140, 64, 255, 0.2);">
        <div class="flex items-center gap-4 p-4 border-b border-p-unlock/20 bg-p-canvas">
          <img id="panel-avatar-img" src="" alt="Inmate avatar" class="w-24 h-24 border-2 border-p-unlock/60 object-cover" />
          <div>
            <p id="panel-name" class="font-display text-sm tracking-widest text-p-unlock"></p>
            <p id="panel-id" class="font-ui text-xs tracking-widest text-p-dim mt-1"></p>
          </div>
        </div>
        <div class="p-4 space-y-2">
          <div class="flex justify-between items-center">
            <span class="font-ui text-p-dim text-[10px] tracking-widest">GENDER</span>
            <span id="panel-gender" class="font-display text-p-accent text-xs"></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-ui text-p-dim text-[10px] tracking-widest">RACE</span>
            <span id="panel-race" class="font-display text-p-accent text-xs"></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-ui text-p-dim text-[10px] tracking-widest">NUTRIQUIREMENTS</span>
            <span id="panel-nutri" class="font-display text-p-accent text-xs"></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-ui text-p-dim text-[10px] tracking-widest">TOKEN</span>
            <span id="panel-token" class="font-display text-p-dim text-xs"></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-ui text-p-dim text-[10px] tracking-widest">STATUS</span>
            <span class="font-ui text-p-teal text-[10px] tracking-widest">● REGISTERED</span>
          </div>
        </div>
        <a href="/unlocked" class="block p-3 text-center font-ui text-p-unlock text-[10px] tracking-widest border-t border-p-unlock/20 hover:bg-p-unlock/10 transition-all">
          VIEW CLASSIFIED FILES →
        </a>
        <a href="/avatar?new=1" class="block p-3 text-center font-ui text-p-teal text-[10px] tracking-widest border-t border-p-unlock/20 hover:bg-p-teal/10 transition-all">
          CREATE ANOTHER AVATAR →
        </a>
        <button id="sign-out-avatar-btn" class="w-full block p-3 text-center font-ui text-p-dim text-[10px] tracking-widest border-t border-p-dim/20 hover:bg-p-red/10 hover:text-p-red transition-all cursor-pointer bg-transparent">
          ✕ SIGN OUT AVATAR
        </button>
      </div>
    </div>

    <button id="mobile-menu-btn" class="md:hidden text-p-dim hover:text-p-accent transition-colors p-2" aria-label="Toggle navigation">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
        <rect y="3" width="20" height="2" rx="1"/>
        <rect y="9" width="20" height="2" rx="1"/>
        <rect y="15" width="20" height="2" rx="1"/>
      </svg>
    </button>
  </div>

  <div id="mobile-nav" class="md:hidden hidden border-t border-p-accent/20 bg-p-canvas">
    <!-- Browse -->
    {browseLinks.map(link => (
      <a href={link.href} class="block px-6 py-3 text-sm font-display tracking-widest text-p-dim hover:text-p-accent hover:bg-p-panel transition-all">
        {link.label}
      </a>
    ))}
    <!-- Divider -->
    <div class="mx-4 border-t border-p-dim/20"></div>
    <!-- Action group -->
    {actionLinks.map(link => (
      <a href={link.href} class="block px-6 py-3 text-sm font-display tracking-widest text-p-teal/70 hover:text-p-teal hover:bg-p-panel transition-all flex items-center gap-2">
        <span class="nav-dot w-2 h-2 rounded-full border border-p-dim/40 flex-shrink-0" data-store-key={link.storeKey}></span>
        {link.label}
      </a>
    ))}
    <!-- Mobile classified link (hidden until unlocked) -->
    <a id="mobile-nav-classified" href="/unlocked" class="hidden px-6 py-3 text-sm font-display tracking-widest text-p-unlock/70 hover:text-p-unlock hover:bg-p-panel transition-all flex items-center gap-2">
      <span class="nav-dot w-2 h-2 rounded-full border border-p-dim/40 flex-shrink-0" id="mobile-nav-dot-classified"></span>
      CLASSIFIED
    </a>
  </div>
</header>

<style>
  @keyframes nav-unlock-pulse {
    0%, 100% {
      color: rgba(140, 64, 255, 0.5);
      text-shadow: none;
    }
    50% {
      color: rgb(140, 64, 255);
      text-shadow: 0 0 8px rgba(140, 64, 255, 0.4);
    }
  }
  @keyframes avatar-thumb-glow {
    0%, 100% {
      box-shadow: 0 0 6px 1px rgba(140, 64, 255, 0.3);
      border-color: rgba(140, 64, 255, 0.5);
    }
    50% {
      box-shadow: 0 0 16px 4px rgba(140, 64, 255, 0.6), 0 0 30px 8px rgba(140, 64, 255, 0.2);
      border-color: rgba(140, 64, 255, 0.9);
    }
  }
</style>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('hidden');
  });

  // Progress dots — fill in based on localStorage state
  document.querySelectorAll('.nav-dot[data-store-key]').forEach(dot => {
    const key = dot.dataset.storeKey;
    const val = localStorage.getItem(key);
    if (val && val !== 'false') {
      dot.style.backgroundColor = 'rgb(26, 224, 194)';
      dot.style.borderColor = 'rgb(26, 224, 194)';
      dot.style.boxShadow = '0 0 4px rgba(26, 224, 194, 0.5)';
    }
  });

  // Unlock classified nav + avatar thumbnail if intake complete
  const isComplete = localStorage.getItem('panopticon_intake_complete') === 'true';
  if (isComplete) {
    // Show CLASSIFIED nav links
    const navLink = document.getElementById('nav-classified');
    if (navLink) {
      navLink.classList.remove('hidden');
      if (window.location.pathname.startsWith('/unlocked')) {
        navLink.classList.add('text-p-unlock', 'border-p-unlock');
        navLink.classList.remove('text-p-unlock/70', 'border-transparent');
      }
    }
    // Classified dot — purple
    const classifiedDot = document.getElementById('nav-dot-classified');
    const mobileClassifiedDot = document.getElementById('mobile-nav-dot-classified');
    [classifiedDot, mobileClassifiedDot].forEach(d => {
      if (d) {
        d.style.backgroundColor = 'rgb(140, 64, 255)';
        d.style.borderColor = 'rgb(140, 64, 255)';
        d.style.boxShadow = '0 0 4px rgba(140, 64, 255, 0.5)';
      }
    });

    const mobileLink = document.getElementById('mobile-nav-classified');
    if (mobileLink) mobileLink.classList.remove('hidden');

    // Show avatar thumbnail
    const avatarThumb = localStorage.getItem('panopticon_avatar_thumb');
    const inmateName = localStorage.getItem('panopticon_inmate_name');
    const inmateId = localStorage.getItem('panopticon_inmate_id');
    const inmateGender = localStorage.getItem('panopticon_inmate_gender');
    const inmateRace = localStorage.getItem('panopticon_inmate_race');
    const inmateNutri = localStorage.getItem('panopticon_inmate_nutri');
    const inmateTok = localStorage.getItem('panopticon_inmate_tok');

    if (avatarThumb && inmateName) {
      // Header avatar
      const wrap = document.getElementById('header-avatar-wrap');
      const img = document.getElementById('header-avatar-img');
      const nameEl = document.getElementById('header-avatar-name');
      const idEl = document.getElementById('header-avatar-id');

      if (wrap) { wrap.classList.remove('hidden'); wrap.classList.add('flex'); }
      if (img) img.src = avatarThumb;
      if (nameEl) nameEl.textContent = inmateName;
      if (idEl) idEl.textContent = inmateId ? '#' + inmateId : '';

      // Populate panel
      const panelImg = document.getElementById('panel-avatar-img');
      const panelName = document.getElementById('panel-name');
      const panelId = document.getElementById('panel-id');
      const panelGender = document.getElementById('panel-gender');
      const panelRace = document.getElementById('panel-race');
      const panelNutri = document.getElementById('panel-nutri');
      const panelToken = document.getElementById('panel-token');

      if (panelImg) panelImg.src = avatarThumb;
      if (panelName) panelName.textContent = inmateName;
      if (panelId) panelId.textContent = inmateId ? '#' + inmateId : '';
      if (panelGender) panelGender.textContent = inmateGender || '—';
      if (panelRace) panelRace.textContent = inmateRace || '—';
      if (panelNutri) panelNutri.textContent = inmateNutri || '—';
      if (panelToken) panelToken.textContent = inmateTok || '—';

      // Toggle panel on click
      wrap?.addEventListener('click', (e) => {
        // Don't toggle if clicking the classified files link inside the panel
        if (e.target.closest('a[href="/unlocked"]')) return;
        const panel = document.getElementById('inmate-panel');
        panel?.classList.toggle('hidden');
      });

      // Close panel when clicking outside
      document.addEventListener('click', (e) => {
        const wrap = document.getElementById('header-avatar-wrap');
        const panel = document.getElementById('inmate-panel');
        if (panel && wrap && !wrap.contains(e.target)) {
          panel.classList.add('hidden');
        }
      });

      // Sign out avatar — clear all inmate localStorage keys and reload
      document.getElementById('sign-out-avatar-btn')?.addEventListener('click', (e) => {
        e.stopPropagation();
        const keys = [
          'panopticon_avatar_created',
          'panopticon_intake_complete',
          'panopticon_avatar_thumb',
          'panopticon_inmate_name',
          'panopticon_inmate_id',
          'panopticon_inmate_tok',
          'panopticon_inmate_gender',
          'panopticon_inmate_race',
          'panopticon_inmate_nutri',
          'panopticon_inmate_email',
        ];
        keys.forEach(k => localStorage.removeItem(k));
        window.location.href = '/';
      });
    }
  }
</script>
