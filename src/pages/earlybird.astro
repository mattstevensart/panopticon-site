---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KICKSTARTER HQ">
  <div class="max-w-5xl mx-auto px-4 py-12">

    <!-- Header -->
    <div class="mb-8 border-b border-p-accent/20 pb-6">
      <p class="font-ui text-p-dim text-xs tracking-[0.4em] mb-2">THE 63RD — COMMISSARY</p>
      <h1 class="font-display text-2xl md:text-3xl text-p-accent tracking-wide">KICKSTARTER HQ</h1>
      <p class="font-ui text-p-dim text-sm mt-2 max-w-xl">
        CREATE YOUR AVATAR · BACK THE CAMPAIGN · WIN A SPOT IN THE NEXT BOOK
      </p>
      <div class="w-16 h-px bg-p-accent mt-4"></div>
    </div>

    <!-- Phase banner -->
    <div class="bg-p-panel border border-p-accent/30 p-3 mb-6 flex items-center gap-3">
      <span id="phase-dot" class="w-2 h-2 rounded-full bg-p-accent animate-pulse flex-shrink-0"></span>
      <span id="phase-text" class="font-ui text-p-accent text-xs tracking-widest">LOADING...</span>
    </div>

    <!-- Countdown (pre-launch only) -->
    <div id="countdown-section" class="bg-p-panel border border-p-accent/20 p-6 mb-8 text-center" style="display:none;">
      <p class="font-ui text-p-dim text-xs tracking-widest mb-4" id="countdown-label">CAMPAIGN LAUNCHES IN</p>
      <div class="flex gap-6 justify-center">
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl text-p-accent" id="cd-days">--</div>
          <div class="font-ui text-p-dim text-[10px] tracking-widest mt-1">DAYS</div>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl text-p-accent" id="cd-hours">--</div>
          <div class="font-ui text-p-dim text-[10px] tracking-widest mt-1">HOURS</div>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl text-p-accent" id="cd-mins">--</div>
          <div class="font-ui text-p-dim text-[10px] tracking-widest mt-1">MINS</div>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl text-p-accent" id="cd-secs">--</div>
          <div class="font-ui text-p-dim text-[10px] tracking-widest mt-1">SECS</div>
        </div>
      </div>
    </div>

    <!-- Three pillars -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
      <div class="border border-[#f59e0b]/30 bg-[#f59e0b]/5 p-5 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#f59e0b] to-[#d97706]"></div>
        <p class="font-display text-sm tracking-widest text-[#f59e0b] mt-2 mb-2">EARLY BIRD PERKS</p>
        <p class="font-comic text-p-text text-sm leading-relaxed mb-3">Make your avatar early, get better rewards.</p>
        <div class="space-y-2 mt-3">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background:#f59e0b;"></span>
            <span class="font-ui text-[10px] tracking-widest" style="color:#f59e0b;">GOLD</span>
            <span class="font-comic text-p-dim text-xs">— Before launch + first 24hrs</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background:#94a3b8;"></span>
            <span class="font-ui text-[10px] tracking-widest" style="color:#94a3b8;">SILVER</span>
            <span class="font-comic text-p-dim text-xs">— 24–48 hrs after launch</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background:#d97706;"></span>
            <span class="font-ui text-[10px] tracking-widest" style="color:#d97706;">BRONZE</span>
            <span class="font-comic text-p-dim text-xs">— 48–72 hrs after launch</span>
          </div>
        </div>
      </div>

      <div class="border border-p-teal/30 bg-p-teal/5 p-5 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-p-teal to-[#0d9488]"></div>
        <p class="font-display text-sm tracking-widest text-p-teal mt-2 mb-2">BACK THE CAMPAIGN</p>
        <p class="font-comic text-p-text text-sm leading-relaxed mb-3">Back us on Kickstarter, then verify your pledge to unlock perks.</p>
        <div id="ks-link-wrap" style="display:none;">
          <a id="ks-link" href="#" target="_blank" class="inline-block mt-2 px-4 py-2 border border-p-teal text-p-teal font-display text-xs tracking-widest hover:bg-p-teal/10 transition-all" style="text-decoration:none;">
            VIEW ON KICKSTARTER →
          </a>
        </div>
        <p id="ks-coming" class="font-ui text-p-dim text-xs tracking-widest mt-2">LAUNCHING MAY 15</p>
      </div>

      <div class="border border-p-unlock/30 bg-p-unlock/5 p-5 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-p-unlock to-[#7c3aed]"></div>
        <p class="font-display text-sm tracking-widest text-p-unlock mt-2 mb-2">CHARACTER LOTTERY</p>
        <p class="font-comic text-p-text text-sm leading-relaxed">One backer's avatar gets drawn into the next issue. Verify your pledge to enter.</p>
        <div class="mt-3 border border-p-unlock/20 bg-p-unlock/10 p-2">
          <p class="font-ui text-p-unlock text-[10px] tracking-widest text-center">AVATAR + PLEDGE = LOTTERY ENTRY</p>
        </div>
      </div>
    </div>

    <!-- NOT YET REGISTERED — prompt to make avatar -->
    <div id="eb-gate" style="display:none;">
      <div class="border-2 border-p-teal/60 bg-p-teal/5 p-8 text-center">
        <p class="font-display text-p-teal text-lg tracking-widest mb-3">GET STARTED</p>
        <p class="font-comic text-p-text text-sm mb-6">Create your avatar and enter your email — you're automatically registered.</p>
        <a href="/avatar" class="inline-block px-8 py-4 border-2 border-p-teal text-p-teal font-display text-sm tracking-widest hover:bg-p-teal/10 transition-all text-center" style="text-decoration:none;">
          CREATE YOUR AVATAR →
        </a>
      </div>
    </div>

    <!-- REGISTERED — status view -->
    <div id="eb-status" style="display:none;">
      <div class="border-2 border-p-teal bg-p-teal/5 p-8">

        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 border-2 border-p-teal/60 overflow-hidden flex-shrink-0">
            <img id="status-avatar" src="" alt="Your avatar" class="w-full h-full object-cover" />
          </div>
          <div class="flex-1">
            <p class="font-display text-sm tracking-widest text-p-teal" id="status-name">—</p>
            <p class="font-ui text-[10px] tracking-widest text-p-dim" id="status-id">—</p>
          </div>
          <div class="text-right">
            <p class="font-display text-p-teal text-xs tracking-widest">✓ REGISTERED</p>
          </div>
        </div>

        <!-- Token -->
        <div class="bg-p-panel border border-p-accent/30 p-5 max-w-md mx-auto mb-6 text-center">
          <p class="font-ui text-p-dim text-[10px] tracking-widest mb-2">YOUR TOKEN</p>
          <p class="font-display text-xl text-p-accent tracking-widest" id="status-token" style="font-family:'Courier New',monospace;">—</p>
          <button id="copy-token" class="mt-3 px-4 py-2 border border-p-dim/40 text-p-dim font-ui text-xs tracking-widest hover:text-p-accent hover:border-p-accent transition-all cursor-pointer bg-transparent">
            COPY TOKEN
          </button>
        </div>

        <!-- Status grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6 text-center">
          <div class="bg-p-panel border border-p-dim/20 p-3">
            <p class="font-ui text-p-dim text-[10px] tracking-widest mb-1">TIER</p>
            <p id="status-tier" class="font-display text-sm tracking-widest"></p>
          </div>
          <div class="bg-p-panel border border-p-dim/20 p-3">
            <p class="font-ui text-p-dim text-[10px] tracking-widest mb-1">PLEDGE</p>
            <p id="status-pledge" class="font-display text-sm tracking-widest"></p>
          </div>
          <div class="bg-p-panel border border-p-dim/20 p-3">
            <p class="font-ui text-p-dim text-[10px] tracking-widest mb-1">LOTTERY</p>
            <p id="status-lottery" class="font-display text-sm tracking-widest"></p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/earlybird-verify" id="verify-cta" class="inline-block px-6 py-3 border-2 border-p-accent text-p-accent font-display text-xs tracking-widest hover:bg-p-accent/10 transition-all text-center" style="text-decoration:none;">
            VERIFY MY PLEDGE →
          </a>
        </div>
      </div>
    </div>

    <!-- CAMPAIGN ENDED -->
    <div id="eb-ended" style="display:none;">
      <div class="border-2 border-p-dim/40 bg-p-panel p-8 text-center">
        <p class="font-display text-p-dim text-lg tracking-widest mb-2">CAMPAIGN ENDED</p>
        <p class="font-comic text-p-dim text-sm mb-6">Registration is closed. Already registered? You can still verify your pledge.</p>
        <a href="/earlybird-verify" class="inline-block px-6 py-3 border border-p-accent text-p-accent font-display text-xs tracking-widest hover:bg-p-accent/10 transition-all text-center" style="text-decoration:none;">
          VERIFY PLEDGE →
        </a>
      </div>
    </div>

    <!-- How it works -->
    <div class="mt-10 border border-p-dim/20 bg-p-panel p-6">
      <p class="font-display text-xs tracking-widest text-p-text mb-4">HOW IT WORKS</p>
      <div class="space-y-3 font-comic text-p-dim text-sm leading-relaxed">
        <p><span class="text-p-teal font-display text-xs">01</span> &nbsp;Create your avatar and enter your email. That's it — you're registered.</p>
        <p><span class="text-p-teal font-display text-xs">02</span> &nbsp;Back the Kickstarter when it launches.</p>
        <p><span class="text-p-teal font-display text-xs">03</span> &nbsp;<a href="/earlybird-verify" class="text-p-accent" style="text-decoration:underline;">Verify your pledge</a> to lock in perks and enter the lottery.</p>
        <p><span class="text-p-unlock font-display text-xs">★</span> &nbsp;One verified backer's avatar gets drawn into the next issue!</p>
      </div>
    </div>

    <p class="font-ui text-p-dim/30 text-xs tracking-widest text-center mt-12">
      PANOPTICON · THE 63RD · ALL TRANSACTIONS LOGGED
    </p>
  </div>
</Layout>


<script>
/* ══════════════════════════════════════════════════════════════════════════
 * KICKSTARTER HQ — Status page (registration happens in avatar maker)
 * ══════════════════════════════════════════════════════════════════════════ */

const CONFIG = {
  launchDate:      '2026-05-15T12:00:00',
  campaignEndDate: '2026-06-14T12:00:00',
  kickstarterUrl: '',
  tiers: {
    gold:      { label: 'GOLD',      color: '#f59e0b' },
    silver:    { label: 'SILVER',    color: '#94a3b8' },
    bronze:    { label: 'BRONZE',    color: '#d97706' },
    supporter: { label: 'SUPPORTER', color: '#1ae0c2' },
  },
  firebase: {
    apiKey: "AIzaSyBXi-F-yL1eq1wPwVkzsB4BP6OyFu5Xdk",
    authDomain: "panopticon-website.firebaseapp.com",
    projectId: "panopticon-website",
    storageBucket: "panopticon-website.firebasestorage.app",
    messagingSenderId: "205882520599",
    appId: "1:205882520599:web:2ade045c34557a359b1852"
  }
};

// Phase detection
function getPhase() {
  const now = Date.now();
  const launch = new Date(CONFIG.launchDate).getTime();
  const end = new Date(CONFIG.campaignEndDate).getTime();
  if (now < launch) return 'pre-launch';
  const h = (now - launch) / 3600000;
  if (h <= 24) return 'gold-window';
  if (h <= 48) return 'silver-window';
  if (h <= 72) return 'bronze-window';
  if (now <= end) return 'active';
  return 'ended';
}

// DB
let db = null;
let useFirebase = false;

async function initDB() {
  if (CONFIG.firebase.apiKey && CONFIG.firebase.apiKey.length > 5) {
    try {
      const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js');
      const { getFirestore, collection, getDocs, query, where } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js');
      const app = initializeApp(CONFIG.firebase);
      db = { fs: getFirestore(app), collection, getDocs, query, where };
      useFirebase = true;
      console.log('✅ Firebase connected');
    } catch(e) { console.warn('Firebase init failed:', e); }
  }
}

async function findByEmail(email) {
  if (!useFirebase || !email) return null;
  const { collection, getDocs, query, where } = db;
  const q = query(collection(db.fs, 'earlybird_registrations'), where('email', '==', email.toLowerCase()));
  const snap = await getDocs(q);
  if (snap.empty) return null;
  const d = snap.docs[0];
  return { id: d.id, ...d.data() };
}

async function findByToken(token) {
  if (!useFirebase || !token) return null;
  const { collection, getDocs, query, where } = db;
  const q = query(collection(db.fs, 'earlybird_registrations'), where('token', '==', token.toUpperCase()));
  const snap = await getDocs(q);
  if (snap.empty) return null;
  const d = snap.docs[0];
  return { id: d.id, ...d.data() };
}

function tierHTML(tier) {
  const t = CONFIG.tiers[tier] || CONFIG.tiers.supporter;
  return `<span style="color:${t.color};">${t.label}</span>`;
}

function updateCountdown(targetDate) {
  const diff = Math.max(0, new Date(targetDate).getTime() - Date.now());
  document.getElementById('cd-days').textContent = Math.floor(diff / 86400000);
  document.getElementById('cd-hours').textContent = Math.floor((diff % 86400000) / 3600000);
  document.getElementById('cd-mins').textContent = Math.floor((diff % 3600000) / 60000);
  document.getElementById('cd-secs').textContent = Math.floor((diff % 60000) / 1000);
}

function setPhase(msg, color = '#388cff') {
  const dot = document.getElementById('phase-dot');
  const text = document.getElementById('phase-text');
  if (dot) dot.style.backgroundColor = color;
  if (text) { text.textContent = msg; text.style.color = color; }
}

// Init
(async function init() {
  await initDB();
  const phase = getPhase();

  // Phase UI
  if (phase === 'pre-launch') {
    document.getElementById('countdown-section').style.display = 'block';
    updateCountdown(CONFIG.launchDate);
    setInterval(() => updateCountdown(CONFIG.launchDate), 1000);
    setPhase('PRE-LAUNCH · MAKE YOUR AVATAR NOW FOR GOLD TIER', '#f59e0b');
  } else if (phase === 'gold-window') {
    document.getElementById('countdown-section').style.display = 'block';
    document.getElementById('countdown-label').textContent = 'GOLD TIER CLOSES IN';
    const goldEnd = new Date(CONFIG.launchDate).getTime() + 24 * 3600000;
    updateCountdown(new Date(goldEnd).toISOString());
    setInterval(() => updateCountdown(new Date(goldEnd).toISOString()), 1000);
    setPhase('LIVE · GOLD TIER WINDOW OPEN', '#f59e0b');
  } else if (phase === 'silver-window') {
    setPhase('LIVE · SILVER TIER WINDOW', '#94a3b8');
  } else if (phase === 'bronze-window') {
    setPhase('LIVE · BRONZE TIER WINDOW', '#d97706');
  } else if (phase === 'active') {
    setPhase('LIVE · SUPPORTER TIER', '#1ae0c2');
  } else if (phase === 'ended') {
    setPhase('CAMPAIGN ENDED', '#5c576f');
  }

  // KS link
  if (CONFIG.kickstarterUrl && phase !== 'pre-launch') {
    document.getElementById('ks-link').href = CONFIG.kickstarterUrl;
    document.getElementById('ks-link-wrap').style.display = 'block';
    document.getElementById('ks-coming').style.display = 'none';
  }

  if (phase === 'ended') {
    document.getElementById('eb-ended').style.display = 'block';
    return;
  }

  // Check if user is registered — try Firebase first, fall back to localStorage
  const savedEmail = localStorage.getItem('panopticon_inmate_email') || localStorage.getItem('panopticon_eb_email');
  const savedToken = localStorage.getItem('panopticon_inmate_tok') || localStorage.getItem('panopticon_eb_token');
  const avatarThumb = localStorage.getItem('panopticon_avatar_thumb');
  const inmateName = localStorage.getItem('panopticon_inmate_name');
  const inmateId = localStorage.getItem('panopticon_inmate_id');

  let reg = null;
  if (savedEmail) reg = await findByEmail(savedEmail);
  if (!reg && savedToken) reg = await findByToken(savedToken);

  if (reg) {
    // Show status
    document.getElementById('eb-status').style.display = 'block';
    setPhase('✓ REGISTERED · ' + (CONFIG.tiers[reg.tier]?.label || 'SUPPORTER') + ' TIER', '#1ae0c2');

    if (reg.avatarThumb || avatarThumb) document.getElementById('status-avatar').src = reg.avatarThumb || avatarThumb;
    document.getElementById('status-name').textContent = reg.name || inmateName || '—';
    document.getElementById('status-id').textContent = reg.inmateId ? '#' + reg.inmateId : '';
    document.getElementById('status-token').textContent = reg.token || savedToken || '—';
    document.getElementById('status-tier').innerHTML = tierHTML(reg.tier);

    if (reg.pledgeVerified) {
      document.getElementById('status-pledge').innerHTML = '<span style="color:#1ae0c2;">✓ VERIFIED</span>';
      document.getElementById('status-lottery').innerHTML = '<span style="color:#8c40ff;">★ ENTERED</span>';
      document.getElementById('verify-cta').textContent = 'VIEW STATUS →';
    } else {
      document.getElementById('status-pledge').innerHTML = '<span style="color:#5c576f;">PENDING</span>';
      document.getElementById('status-lottery').innerHTML = '<span style="color:#5c576f;">VERIFY TO ENTER</span>';
    }

    document.getElementById('copy-token')?.addEventListener('click', () => {
      navigator.clipboard.writeText(reg.token || savedToken || '');
      document.getElementById('copy-token').textContent = '✓ COPIED';
      setTimeout(() => { document.getElementById('copy-token').textContent = 'COPY TOKEN'; }, 2000);
    });
  } else {
    // Not registered — show CTA to create avatar
    document.getElementById('eb-gate').style.display = 'block';
  }
})();
</script>
