---
import Layout from '../../layouts/Layout.astro';

const excerptPages = [
  { src: '/images/read/webtoon-13.jpg', alt: 'Panopticon Issue 1 — Page 13' },
  { src: '/images/read/webtoon-14.jpg', alt: 'Panopticon Issue 1 — Page 14' },
  { src: '/images/read/webtoon-15.jpg', alt: 'Panopticon Issue 1 — Page 15' },
  { src: '/images/read/webtoon-16.jpg', alt: 'Panopticon Issue 1 — Page 16' },
];

const sneakPeekPages = [
  { src: '/images/read/sneak-peek-issue5-p6.jpg', alt: 'Panopticon Issue 5 — Page 6', label: 'ISSUE 5' },
  { src: '/images/read/sneak-peek-issue6-p18.jpg', alt: 'Panopticon Issue 6 — Page 18', label: 'ISSUE 6' },
  { src: '/images/read/sneak-peek-issue6-p2.jpg', alt: 'Panopticon Issue 6 — Page 2', label: 'ISSUE 6' },
];
---

<Layout title="READ">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="mb-12 border-b border-p-accent/20 pb-8">
      <h1 class="font-display text-3xl md:text-4xl text-p-text tracking-wide">READ PANOPTICON</h1>
      <p class="font-body text-p-dim text-sm mt-4 max-w-2xl leading-relaxed">
        A <span class="text-p-teal">new inmate</span> joins the Panopticon; a timeless, single chamber prison where prisoners
        don't know when, or even if they are being watched. As he navigates the <span class="text-p-teal">strict codes</span> of his fellow
        convicts, he must unravel the mysteries of the facility, its <span class="text-p-teal">unseen wardens</span>, and the chilling
        possibility that to stay may be more deadly than escape.
      </p>
      <div class="w-16 h-px bg-p-accent mt-4"></div>

      <div class="mt-8 bg-p-panel/60 border border-p-unlock/20 p-6">
        <h3 class="font-display text-sm text-p-unlock tracking-widest mb-3">WHERE CAN I READ PANOPTICON?</h3>
        <p class="font-body text-p-text text-sm leading-relaxed">
          Panopticon ACT 1 is going to be released in print this spring on <span class="text-p-teal">Kickstarter</span> and digitally soon after. More to come very soon. For now, <a href="/avatar" class="text-p-teal hover:text-p-accent transition-colors">make a character</a>, <a href="/scan" class="text-p-teal hover:text-p-accent transition-colors">scan in</a>, and help build the world of Panopticon!
        </p>
      </div>
    </div>

    <!-- Act 1 Excerpt -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <h2 class="font-display text-2xl md:text-3xl text-p-text tracking-wide">EXCERPT FROM ACT 1</h2>
        <div class="w-24 h-px bg-p-teal mx-auto mt-4"></div>
      </div>

      <div class="relative border border-p-teal/30 overflow-hidden">
        <!-- Scanline overlay -->
        <div class="absolute inset-0 bg-scanline opacity-10 pointer-events-none z-10"></div>

        <!-- Corner brackets -->
        <div class="absolute top-3 left-3 w-5 h-5 border-t-2 border-l-2 border-p-teal/70 z-20"></div>
        <div class="absolute top-3 right-3 w-5 h-5 border-t-2 border-r-2 border-p-teal/70 z-20"></div>

        <div class="flex flex-col">
          {excerptPages.map(page => (
            <img src={page.src} alt={page.alt} class="w-full h-auto block comic-zoomable" loading="lazy" style="cursor: zoom-in;" />
          ))}
        </div>

        <!-- Bottom brackets -->
        <div class="absolute bottom-3 left-3 w-5 h-5 border-b-2 border-l-2 border-p-teal/70 z-20"></div>
        <div class="absolute bottom-3 right-3 w-5 h-5 border-b-2 border-r-2 border-p-teal/70 z-20"></div>
      </div>

      <p class="text-center font-ui text-p-dim/50 text-xs tracking-widest mt-4">
        PANOPTICON ISSUE 1 &nbsp;·&nbsp; PAGES 13–16
      </p>
    </section>

    <!-- Sneak Peek — Act 2 -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <h2 class="font-display text-2xl md:text-3xl text-p-text tracking-wide">SNEAK PEEK — ACT 2</h2>
        <p class="font-body text-p-dim text-sm mt-3">A quick look at what's to come.</p>
        <div class="w-24 h-px bg-p-red mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {sneakPeekPages.map(page => (
          <div class="relative border border-p-red/30 overflow-hidden group">
            <!-- Corner brackets -->
            <div class="absolute top-2 left-2 w-4 h-4 border-t-2 border-l-2 border-p-red/50 z-20"></div>
            <div class="absolute top-2 right-2 w-4 h-4 border-t-2 border-r-2 border-p-red/50 z-20"></div>
            <div class="absolute bottom-2 left-2 w-4 h-4 border-b-2 border-l-2 border-p-red/50 z-20"></div>
            <div class="absolute bottom-2 right-2 w-4 h-4 border-b-2 border-r-2 border-p-red/50 z-20"></div>

            <img src={page.src} alt={page.alt} class="w-full h-auto block transition-transform duration-500 group-hover:scale-105 comic-zoomable" loading="lazy" style="cursor: zoom-in;" />

            <!-- Label overlay -->
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-p-root/90 to-transparent pt-10 pb-3 px-3 z-10">
              <span class="font-display text-xs tracking-widest text-p-red/80">{page.label}</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Lightbox zoom viewer -->
  <div id="lightbox" style="display: none; position: fixed; inset: 0; z-index: 9000; background: rgba(10, 10, 15, 0.95); cursor: grab; touch-action: none; overflow: hidden;">
    <!-- Close button -->
    <button id="lb-close" style="position: absolute; top: 16px; right: 16px; z-index: 9010; width: 44px; height: 44px; background: rgba(23, 23, 33, 0.8); border: 2px solid rgba(56, 140, 255, 0.4); color: rgb(214, 214, 224); font-family: 'Orbitron'; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s;">✕</button>
    <!-- Zoom controls -->
    <div style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 9010; display: flex; gap: 8px; align-items: center;">
      <button id="lb-zoom-out" style="width: 40px; height: 40px; background: rgba(23, 23, 33, 0.8); border: 2px solid rgba(56, 140, 255, 0.4); color: rgb(214, 214, 224); font-family: 'Orbitron'; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center;">−</button>
      <span id="lb-zoom-level" style="color: rgb(92, 87, 111); font-family: 'Electrolize'; font-size: 12px; letter-spacing: 2px; min-width: 50px; text-align: center;">100%</span>
      <button id="lb-zoom-in" style="width: 40px; height: 40px; background: rgba(23, 23, 33, 0.8); border: 2px solid rgba(56, 140, 255, 0.4); color: rgb(214, 214, 224); font-family: 'Orbitron'; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center;">+</button>
    </div>
    <p style="position: absolute; bottom: 68px; left: 50%; transform: translateX(-50%); z-index: 9010; color: rgb(92, 87, 111); font-family: 'Electrolize'; font-size: 11px; letter-spacing: 2px; pointer-events: none;">SCROLL TO ZOOM · DRAG TO PAN</p>
    <!-- Image container -->
    <div id="lb-container" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;">
      <img id="lb-img" src="" alt="" style="max-width: none; max-height: none; transform-origin: center center; transition: none; user-select: none; -webkit-user-drag: none;" draggable="false" />
    </div>
  </div>
</Layout>

<script>
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbClose = document.getElementById('lb-close');
  const lbZoomIn = document.getElementById('lb-zoom-in');
  const lbZoomOut = document.getElementById('lb-zoom-out');
  const lbZoomLevel = document.getElementById('lb-zoom-level');

  let scale = 1;
  let panX = 0;
  let panY = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let panStartX = 0;
  let panStartY = 0;

  function updateTransform() {
    lbImg.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
    lbZoomLevel.textContent = Math.round(scale * 100) + '%';
  }

  function openLightbox(src, alt) {
    lbImg.src = src;
    lbImg.alt = alt || '';
    scale = 1;
    panX = 0;
    panY = 0;
    lightbox.style.display = 'block';
    document.body.style.overflow = 'hidden';

    // Fit image to viewport
    lbImg.onload = () => {
      const vw = window.innerWidth * 0.9;
      const vh = window.innerHeight * 0.85;
      const iw = lbImg.naturalWidth;
      const ih = lbImg.naturalHeight;
      scale = Math.min(vw / iw, vh / ih, 1);
      updateTransform();
    };
    // If already cached
    if (lbImg.complete && lbImg.naturalWidth) {
      const vw = window.innerWidth * 0.9;
      const vh = window.innerHeight * 0.85;
      scale = Math.min(vw / lbImg.naturalWidth, vh / lbImg.naturalHeight, 1);
      updateTransform();
    }
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
    lbImg.src = '';
  }

  // Click to open
  document.querySelectorAll('.comic-zoomable').forEach(img => {
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  // Close
  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target.id === 'lb-container') closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.style.display === 'block') closeLightbox();
  });

  // Zoom buttons
  lbZoomIn.addEventListener('click', (e) => {
    e.stopPropagation();
    scale = Math.min(scale * 1.3, 5);
    updateTransform();
  });
  lbZoomOut.addEventListener('click', (e) => {
    e.stopPropagation();
    scale = Math.max(scale / 1.3, 0.2);
    updateTransform();
  });

  // Scroll to zoom
  lightbox.addEventListener('wheel', (e) => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? 0.85 : 1.18;
    const newScale = Math.max(0.2, Math.min(5, scale * delta));

    // Zoom toward cursor position
    const rect = lbImg.getBoundingClientRect();
    const cx = e.clientX - rect.left - rect.width / 2;
    const cy = e.clientY - rect.top - rect.height / 2;
    const ratio = 1 - newScale / scale;
    panX += cx * ratio;
    panY += cy * ratio;

    scale = newScale;
    updateTransform();
  }, { passive: false });

  // Drag to pan (mouse)
  lightbox.addEventListener('mousedown', (e) => {
    if (e.target.closest('button')) return;
    isDragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    panStartX = panX;
    panStartY = panY;
    lightbox.style.cursor = 'grabbing';
    e.preventDefault();
  });
  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    panX = panStartX + (e.clientX - dragStartX);
    panY = panStartY + (e.clientY - dragStartY);
    updateTransform();
  });
  window.addEventListener('mouseup', () => {
    if (isDragging) {
      isDragging = false;
      lightbox.style.cursor = 'grab';
    }
  });

  // Touch pan + pinch zoom
  let touches = [];
  let lastPinchDist = 0;

  lightbox.addEventListener('touchstart', (e) => {
    if (e.target.closest('button')) return;
    touches = Array.from(e.touches);
    if (touches.length === 1) {
      isDragging = true;
      dragStartX = touches[0].clientX;
      dragStartY = touches[0].clientY;
      panStartX = panX;
      panStartY = panY;
    } else if (touches.length === 2) {
      isDragging = false;
      lastPinchDist = Math.hypot(touches[1].clientX - touches[0].clientX, touches[1].clientY - touches[0].clientY);
    }
  }, { passive: true });

  lightbox.addEventListener('touchmove', (e) => {
    if (e.target.closest('button')) return;
    e.preventDefault();
    const t = Array.from(e.touches);
    if (t.length === 1 && isDragging) {
      panX = panStartX + (t[0].clientX - dragStartX);
      panY = panStartY + (t[0].clientY - dragStartY);
      updateTransform();
    } else if (t.length === 2) {
      const dist = Math.hypot(t[1].clientX - t[0].clientX, t[1].clientY - t[0].clientY);
      if (lastPinchDist > 0) {
        scale = Math.max(0.2, Math.min(5, scale * (dist / lastPinchDist)));
        updateTransform();
      }
      lastPinchDist = dist;
    }
  }, { passive: false });

  lightbox.addEventListener('touchend', () => {
    isDragging = false;
    lastPinchDist = 0;
  });

  // Double-click to toggle zoom
  lbImg.addEventListener('dblclick', (e) => {
    e.stopPropagation();
    if (scale > 1.5) {
      scale = 1;
      panX = 0;
      panY = 0;
    } else {
      // Zoom to 2.5x centered on click point
      const rect = lbImg.getBoundingClientRect();
      const cx = e.clientX - rect.left - rect.width / 2;
      const cy = e.clientY - rect.top - rect.height / 2;
      const newScale = 2.5;
      const ratio = 1 - newScale / scale;
      panX += cx * ratio;
      panY += cy * ratio;
      scale = newScale;
    }
    updateTransform();
  });
</script>
