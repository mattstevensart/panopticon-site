---
import Layout from '../../layouts/Layout.astro';

const excerptPages = [
  { src: '/images/read/webtoon-13.jpg', alt: 'Panopticon Issue 1 — Page 13' },
  { src: '/images/read/webtoon-14.jpg', alt: 'Panopticon Issue 1 — Page 14' },
  { src: '/images/read/webtoon-15.jpg', alt: 'Panopticon Issue 1 — Page 15' },
  { src: '/images/read/webtoon-16.jpg', alt: 'Panopticon Issue 1 — Page 16' },
];
---

<Layout title="READ">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="mb-12 border-b border-p-accent/20 pb-8">
      <h1 class="font-display text-3xl md:text-4xl text-p-text tracking-wide">READ PANOPTICON</h1>
      <p class="font-body text-p-dim text-sm mt-4 max-w-2xl leading-relaxed">
        A <span class="text-p-teal">new inmate</span> joins the Panopticon; a timeless, single chamber prison where prisoners
        don't know when, or even if they are being watched. As he navigates the <span class="text-p-teal">strict codes</span> of his fellow
        convicts, he must unravel the mysteries of the facility, its <span class="text-p-teal">unseen wardens</span>, and the chilling
        possibility that to stay may be more deadly than escape.
      </p>
      <div class="w-16 h-px bg-p-accent mt-4"></div>
    </div>

    <!-- Act 1 Excerpt -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <h2 class="font-display text-2xl md:text-3xl text-p-text tracking-wide">EXCERPT FROM ACT 1</h2>
        <div class="w-24 h-px bg-p-teal mx-auto mt-4"></div>
      </div>

      <div class="relative border border-p-teal/30 overflow-hidden">
        <!-- Scanline overlay -->
        <div class="absolute inset-0 bg-scanline opacity-10 pointer-events-none z-10"></div>

        <!-- Corner brackets -->
        <div class="absolute top-3 left-3 w-5 h-5 border-t-2 border-l-2 border-p-teal/70 z-20"></div>
        <div class="absolute top-3 right-3 w-5 h-5 border-t-2 border-r-2 border-p-teal/70 z-20"></div>

        <div class="flex flex-col">
          {excerptPages.map(page => (
            <img src={page.src} alt={page.alt} class="w-full h-auto block" loading="lazy" />
          ))}
        </div>

        <!-- Bottom brackets -->
        <div class="absolute bottom-3 left-3 w-5 h-5 border-b-2 border-l-2 border-p-teal/70 z-20"></div>
        <div class="absolute bottom-3 right-3 w-5 h-5 border-b-2 border-r-2 border-p-teal/70 z-20"></div>
      </div>

      <p class="text-center font-ui text-p-dim/50 text-xs tracking-widest mt-4">
        PANOPTICON ISSUE 1 &nbsp;·&nbsp; PAGES 13–16
      </p>
    </section>
  </div>
</Layout>
