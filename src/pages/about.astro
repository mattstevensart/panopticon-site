---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ABOUT">
  <!-- Itsahk head watermark background -->
  <div style="position: fixed; inset: 0; z-index: 0; pointer-events: none; display: flex; align-items: center; justify-content: center;">
    <img src="/images/itsahk-head.jpg" alt="" style="width: 70vmin; max-width: 700px; opacity: 0.25; filter: brightness(1.8) contrast(1.1); user-select: none; -webkit-user-drag: none; mask-image: radial-gradient(ellipse 50% 50% at center, black 65%, transparent 95%); -webkit-mask-image: radial-gradient(ellipse 50% 50% at center, black 65%, transparent 95%);" />
  </div>
  <div class="max-w-4xl mx-auto px-4 py-16" style="position: relative; z-index: 1;">
    <div class="mb-12 border-b border-p-accent/20 pb-8">
      <h1 class="font-display text-3xl md:text-4xl text-p-text tracking-wide">ABOUT THE PROJECT</h1>
      <div class="w-16 h-px bg-p-accent mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="md:col-span-2 space-y-8 font-comic text-p-text leading-relaxed">
        <div class="bg-p-panel border-l-2 border-p-accent p-6">
          <p class="font-ui text-p-dim text-xs tracking-widest mb-3">SYNOPSIS</p>
          <p class="text-base">
            A new inmate joins the Panopticon — a timeless, single-chamber prison where prisoners
            don't know when, or even if, they are being watched. As he navigates the strict codes
            of his fellow convicts, he must unravel the mysteries of the facility, its unseen wardens,
            and the chilling possibility that to stay may be more deadly than escape.
          </p>
          <p class="text-base mt-4 text-p-dim italic">
            Graphic. Psychological. Multi-layered.
          </p>
        </div>

        <div>
          <h2 class="font-display text-sm tracking-widest text-p-accent mb-4">THEMES</h2>
          <div class="space-y-2">
            {[
              'The psychology of oppressive surveillance',
              'The unreliability of memory',
              'The price of loyalty',
            ].map(theme => (
              <div class="flex items-start gap-3">
                <span class="text-p-teal mt-1">⊗</span>
                <span class="font-comic text-p-dim text-sm">{theme}</span>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="font-display text-sm tracking-widest text-p-accent mb-4">THE CREATOR</h2>
          <p class="text-p-dim">
            Matt Stevens is an illustrator, comic book artist and a high school art teacher.
            He is the author and artist for Panopticon and the artist on the series{' '}
            <a href="https://thedigitalpools.com" target="_blank" rel="noopener noreferrer"
               class="text-p-accent hover:text-p-teal transition-colors underline underline-offset-2">
              Digital Pools
            </a>{' '}
            with collaborator Alex Robnett. Visit{' '}
            <a href="https://thedarkwebcomics.com" target="_blank" rel="noopener noreferrer"
               class="text-p-accent hover:text-p-teal transition-colors underline underline-offset-2">
              thedarkwebcomics.com
            </a>{' '}
            for more.
          </p>
        </div>

      </div>

      <div class="space-y-4">
        <div class="bg-p-panel border border-p-accent/20 p-4">
          <p class="font-ui text-p-dim text-xs tracking-widest mb-4">PROJECT DOSSIER</p>
          <div class="space-y-3">
            {[
              { label: 'STATUS',  value: 'ONGOING' },
              { label: 'GENRE',   value: 'SCI-FI / PRISON' },
              { label: 'FORMAT',  value: 'GRAPHIC NOVEL' },
              { label: 'RATING',  value: 'MATURE' },
            ].map(item => (
              <div class="flex justify-between items-center border-b border-p-accent/10 pb-2">
                <span class="font-ui text-p-dim text-xs tracking-widest">{item.label}</span>
                <span class="font-display text-p-accent text-xs">{item.value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-p-panel border border-p-teal/20 p-4">
          <p class="font-ui text-p-teal text-xs tracking-widest mb-3">SOCIAL / CONTACT</p>
          <div class="space-y-2 text-xs font-ui text-p-dim">
            <p>→ Instagram: <a href="https://instagram.com/panopticoncomic" target="_blank" rel="noopener noreferrer" class="text-p-teal hover:text-p-accent transition-colors">@panopticoncomic</a></p>
            <p>→ Instagram: <a href="https://instagram.com/darkwebcomics_" target="_blank" rel="noopener noreferrer" class="text-p-teal hover:text-p-accent transition-colors">@darkwebcomics_</a></p>
            <p>→ TikTok: <a href="https://tiktok.com/@mattstevensart" target="_blank" rel="noopener noreferrer" class="text-p-teal hover:text-p-accent transition-colors">@mattstevensart</a></p>
            <p>→ Twitter: <a href="https://twitter.com/mattstevensnow" target="_blank" rel="noopener noreferrer" class="text-p-teal hover:text-p-accent transition-colors">@mattstevensnow</a></p>
            <p>→ Email: <a href="mailto:mattstevensart@gmail.com" class="text-p-teal hover:text-p-accent transition-colors">mattstevensart@gmail.com</a></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="mt-16 border-t border-p-accent/20 pt-12">
      <div class="max-w-2xl">
        <h2 class="font-display text-sm tracking-widest text-p-teal mb-2">⚑ TRANSMIT MESSAGE TO FACILITY ADMINISTRATION</h2>
        <p class="font-comic text-p-dim text-sm mb-8">All transmissions are logged and monitored.</p>

        <form id="contact-form" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block font-ui text-p-dim text-xs tracking-widest mb-2">DESIGNATION</label>
              <input type="text" name="name" required placeholder="YOUR NAME"
                class="w-full px-4 py-3 bg-p-root border-2 border-p-dim/30 text-p-text font-ui text-sm tracking-wide outline-none transition-colors focus:border-p-red"
                style="letter-spacing: 1px;" />
            </div>
            <div>
              <label class="block font-ui text-p-dim text-xs tracking-widest mb-2">FREQUENCY</label>
              <input type="email" name="email" required placeholder="YOUR EMAIL"
                class="w-full px-4 py-3 bg-p-root border-2 border-p-dim/30 text-p-text font-ui text-sm tracking-wide outline-none transition-colors focus:border-p-red"
                style="letter-spacing: 1px;" />
            </div>
          </div>
          <div>
            <label class="block font-ui text-p-dim text-xs tracking-widest mb-2">TRANSMISSION</label>
            <textarea name="message" required rows="5" placeholder="ENTER YOUR MESSAGE"
              class="w-full px-4 py-3 bg-p-root border-2 border-p-dim/30 text-p-text font-ui text-sm tracking-wide outline-none transition-colors focus:border-p-red resize-none"
              style="letter-spacing: 1px;"></textarea>
          </div>
          <div class="flex items-center gap-4">
            <button type="submit" id="contact-submit"
              class="px-6 py-3 bg-p-red border-2 border-p-red font-ui text-sm font-bold tracking-widest cursor-pointer transition-all hover:bg-transparent hover:text-p-red"
              style="color: rgb(10, 10, 15);">
              TRANSMIT →
            </button>
            <span id="contact-status" class="font-ui text-sm tracking-wide" style="display: none;"></span>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const status = document.getElementById('contact-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'TRANSMITTING...';
    status.style.display = 'none';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    data.access_key = 'bbd36a00-ce64-4810-b3b5-829e8504351d';

    try {
      const resp = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data)
      });

      if (resp.ok) {
        status.textContent = 'TRANSMISSION RECEIVED. MESSAGE LOGGED.';
        status.style.color = 'rgb(26, 224, 194)';
        status.style.display = 'inline';
        form.reset();
      } else {
        throw new Error('Failed');
      }
    } catch(err) {
      status.textContent = 'TRANSMISSION FAILED. TRY AGAIN.';
      status.style.color = 'rgb(230, 38, 26)';
      status.style.display = 'inline';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'TRANSMIT →';
  });
</script>
