---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="FILE 004 — THE TOWER">
  <div id="gate-wrapper">

    <!-- Access denied -->
    <div id="access-denied" class="min-h-[80vh] flex flex-col items-center justify-center px-4">
      <div class="border border-p-red/50 bg-p-panel p-10 text-center max-w-md shadow-red-glow">
        <div class="text-p-red text-5xl font-display mb-4">⊗</div>
        <h1 class="font-display text-xl tracking-widest text-p-red mb-4">ACCESS DENIED</h1>
        <p class="font-ui text-p-dim text-sm mb-6">
          INMATE PROFILE NOT ON FILE.<br/>
          COMPLETE INTAKE PROCESSING TO CONTINUE.
        </p>
        <a href="/avatar" class="inline-block px-8 py-3 border border-p-teal text-p-teal font-display text-xs tracking-widest hover:bg-p-teal/10 transition-all">
          GO TO INTAKE →
        </a>
      </div>
    </div>

    <!-- Access granted -->
    <div id="access-granted" class="hidden">
      <div class="max-w-4xl mx-auto px-4 py-16">

        <!-- Back link -->
        <a href="/unlocked" class="inline-flex items-center gap-2 font-ui text-p-unlock/60 text-xs tracking-widest hover:text-p-unlock transition-all mb-8">
          ← CLASSIFIED FILES
        </a>

        <!-- Header -->
        <div class="mb-12 border-b border-p-unlock/30 pb-8">
          <p class="font-ui text-p-unlock text-xs tracking-[0.4em] mb-2">FILE 004</p>
          <h1 class="font-display text-2xl md:text-3xl tracking-wide text-p-text">THE TOWER</h1>
          <div class="w-16 h-px bg-p-unlock mt-4"></div>
        </div>

        <!-- Tower image with fade to black -->
        <div class="relative overflow-hidden">
          <img
            src="/images/read/webtoon-28.jpg"
            alt="The Tower"
            class="w-full h-auto block"
          />
          <!-- Fade to black gradient overlay — extended for protocols -->
          <div class="absolute bottom-0 left-0 w-full" style="height: 70%; background: linear-gradient(to bottom, transparent 0%, rgba(10,10,15,0.5) 20%, rgba(10,10,15,0.8) 40%, rgba(10,10,15,0.95) 60%, rgb(10,10,15) 80%);"></div>

          <!-- Overlaid content in the fade -->
          <div class="absolute bottom-0 left-0 w-full px-6 pb-10 md:px-12 md:pb-16 z-10">
            <!-- Welcome text -->
            <p class="font-display text-sm md:text-base tracking-wide leading-relaxed text-center max-w-2xl mx-auto" style="color: rgb(26, 224, 194); text-shadow: 0 0 12px rgba(26, 224, 194, 0.5), 0 0 30px rgba(26, 224, 194, 0.2);">
              Welcome to the Panopticon — our state of the art, all-seeing prison design allowing our central tower to observe all inmates anonymously. You will comply.
            </p>
            <p class="font-display text-sm md:text-base tracking-wide text-center max-w-2xl mx-auto mt-4 glitch-surveillance" style="color: rgb(230, 38, 26);">
              <span class="glitch-text" data-text="Surveillance is mandatory.">Surveillance is mandatory.</span>
            </p>

            <!-- Protocols overlaid -->
            <div class="mt-10 max-w-xl mx-auto border border-p-red/30 bg-p-root/40 backdrop-blur-sm p-6 md:p-8" style="box-shadow: 0 0 40px rgba(230, 38, 26, 0.08);">
              <h3 class="font-display text-xs tracking-[0.3em] text-p-red mb-5" style="text-shadow: 0 0 8px rgba(230, 38, 26, 0.4);">PROTOCOLS</h3>
              <ul class="space-y-3 font-ui text-xs md:text-sm text-p-dim/90 leading-relaxed">
                <li class="flex items-start gap-3">
                  <span class="text-p-red mt-0.5">▸</span>
                  <span>All inmates must follow codes at all times.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-p-red mt-0.5">▸</span>
                  <span>Klaxon signals must be followed.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-p-red mt-0.5">▸</span>
                  <span>Do not approach Tower.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-p-red mt-0.5">▸</span>
                  <span>There is no sharing, trading, or disposing of Nutri. All calories must be consumed by inmate.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-p-red mt-0.5">▸</span>
                  <span>Do not remove ID# from prison grays.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-p-red mt-0.5">▸</span>
                  <span>Do not attempt to access unauthorized areas, panels, surfaces.</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Bottom nav -->
        <div class="mt-12 pt-8 border-t border-p-unlock/10 flex items-center justify-between">
          <a href="/unlocked/003" class="font-ui text-p-unlock/60 text-xs tracking-widest hover:text-p-unlock transition-all">← FILE 003</a>
          <a href="/unlocked" class="font-ui text-p-unlock/60 text-xs tracking-widest hover:text-p-unlock transition-all">ALL FILES →</a>
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .glitch-surveillance {
    position: relative;
  }
  .glitch-text {
    position: relative;
    display: inline-block;
    animation: glitch-flicker 4s infinite;
    text-shadow: 0 0 10px rgba(230, 38, 26, 0.6), 0 0 30px rgba(230, 38, 26, 0.3);
  }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .glitch-text::before {
    color: rgb(230, 38, 26);
    animation: glitch-shift-1 3.2s infinite steps(2, start);
    clip-path: inset(0 0 60% 0);
    text-shadow: -3px 0 rgba(0, 255, 200, 0.7);
  }
  .glitch-text::after {
    color: rgb(230, 38, 26);
    animation: glitch-shift-2 2.7s infinite steps(2, start);
    clip-path: inset(40% 0 0 0);
    text-shadow: 3px 0 rgba(140, 64, 255, 0.7);
  }

  @keyframes glitch-flicker {
    0%, 2%, 4%, 6%, 100% {
      opacity: 1;
      transform: translate(0);
      filter: none;
    }
    1% {
      opacity: 0.7;
      transform: translate(-4px, 1px) skewX(-2deg);
      filter: blur(1px);
    }
    3% {
      opacity: 0.9;
      transform: translate(3px, -1px) skewX(1deg);
      filter: hue-rotate(20deg);
    }
    5% {
      opacity: 0.6;
      transform: translate(-2px, 2px);
      filter: blur(0.5px);
    }
    20%, 20.5% {
      opacity: 0.3;
      transform: translate(6px, 0) skewX(-5deg);
      filter: blur(2px) brightness(2);
    }
    20.5%, 21% {
      opacity: 1;
      transform: translate(-3px, 1px);
    }
    45%, 45.3% {
      transform: translate(0, -3px) scaleY(1.05);
      filter: hue-rotate(-30deg);
    }
    45.6% {
      transform: translate(0);
      filter: none;
    }
    70%, 70.2% {
      opacity: 0.4;
      transform: translate(5px, -1px) skewX(3deg);
      filter: blur(1px) contrast(2);
    }
    70.4% {
      opacity: 1;
      transform: translate(-2px, 0);
    }
    70.6% {
      transform: translate(0);
      filter: none;
    }
    90%, 90.1% {
      opacity: 0;
    }
    90.2% {
      opacity: 1;
      transform: translate(3px, 2px);
      filter: hue-rotate(10deg) blur(0.5px);
    }
    90.5% {
      transform: translate(0);
      filter: none;
    }
  }

  @keyframes glitch-shift-1 {
    0%, 100% { clip-path: inset(0 0 85% 0); transform: translate(0); }
    10% { clip-path: inset(15% 0 60% 0); transform: translate(-5px, 0); }
    20% { clip-path: inset(40% 0 30% 0); transform: translate(4px, 0); }
    30% { clip-path: inset(70% 0 5% 0); transform: translate(-3px, 0); }
    40% { clip-path: inset(5% 0 75% 0); transform: translate(6px, 0); }
    50% { clip-path: inset(55% 0 20% 0); transform: translate(-2px, 0); }
    60% { clip-path: inset(25% 0 55% 0); transform: translate(3px, 0); }
    70% { clip-path: inset(80% 0 0% 0); transform: translate(-4px, 0); }
    80% { clip-path: inset(0% 0 90% 0); transform: translate(5px, 0); }
    90% { clip-path: inset(45% 0 40% 0); transform: translate(-6px, 0); }
  }

  @keyframes glitch-shift-2 {
    0%, 100% { clip-path: inset(80% 0 0 0); transform: translate(0); }
    15% { clip-path: inset(0 0 70% 0); transform: translate(4px, 0); }
    25% { clip-path: inset(50% 0 20% 0); transform: translate(-6px, 0); }
    35% { clip-path: inset(10% 0 60% 0); transform: translate(3px, 0); }
    45% { clip-path: inset(65% 0 10% 0); transform: translate(-5px, 0); }
    55% { clip-path: inset(30% 0 45% 0); transform: translate(6px, 0); }
    65% { clip-path: inset(75% 0 5% 0); transform: translate(-3px, 0); }
    75% { clip-path: inset(20% 0 55% 0); transform: translate(4px, 0); }
    85% { clip-path: inset(60% 0 15% 0); transform: translate(-4px, 0); }
    95% { clip-path: inset(5% 0 80% 0); transform: translate(5px, 0); }
  }
</style>

<script>
  const isComplete = localStorage.getItem('panopticon_intake_complete') === 'true';
  if (isComplete) {
    document.getElementById('access-denied')?.classList.add('hidden');
    document.getElementById('access-granted')?.classList.remove('hidden');
  }
</script>
