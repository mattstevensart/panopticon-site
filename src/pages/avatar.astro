    };
    let fbDb = null;
    let fbReady = false;
    async function initFirebase() {
      try {
        const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js');
        const { getFirestore, collection, addDoc, getDocs, query, where } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js');
        const app = initializeApp(FB_CONFIG);
        fbDb = { fs: getFirestore(app), collection, addDoc, getDocs, query, where };
        fbReady = true;
        console.log('✅ Firebase connected (avatar)');
      } catch(e) { console.warn('Firebase init failed:', e); }
    }
    initFirebase();

    function calculateTier() {
      const launch = new Date('2026-05-14T08:00:00').getTime();
      const now = Date.now();
      if (now < launch) return 'gold';
      const h = (now - launch) / 3600000;
      if (h <= 24) return 'gold';
      if (h <= 48) return 'silver';
      if (h <= 72) return 'bronze';
      return 'supporter';
    }

    async function registerInFirebase(email, name, inmateId, token, avatarThumb) {
      if (!fbReady) return;
      try {
        const { collection, getDocs, query, where, addDoc } = fbDb;
        const { doc, updateDoc } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js');
        // Check if email exists — update avatar if so, otherwise create new
        const q = query(collection(fbDb.fs, 'earlybird_registrations'), where('email', '==', email.toLowerCase()));
        const snap = await getDocs(q);
        if (!snap.empty) {
          const existing = snap.docs[0];
          await updateDoc(doc(fbDb.fs, 'earlybird_registrations', existing.id), {
            name: name || existing.data().name,
            inmateId: inmateId || existing.data().inmateId,
            token: token || existing.data().token,
            avatarThumb: avatarThumb || existing.data().avatarThumb,
          });
          localStorage.setItem('panopticon_eb_token', token || inmateId || '');
          localStorage.setItem('panopticon_eb_email', email.toLowerCase());
          console.log('✅ Updated existing registration');
          return;
        }
        await addDoc(collection(fbDb.fs, 'earlybird_registrations'), {
          name: name || '',
          inmateId: inmateId || token || '',
          email: email.toLowerCase(),
          token: token || '',
          tier: calculateTier(),
          avatarThumb: avatarThumb || '',
          registeredAt: new Date().toISOString(),
          pledgeVerified: false,
          backerName: '',
          backerEmail: '',
          pledgeAmount: '',
          verifiedAt: '',
          lotteryEligible: false,
          lotteryWinner: false,
        });
        localStorage.setItem('panopticon_eb_token', token || inmateId || '');
        localStorage.setItem('panopticon_eb_email', email.toLowerCase());
        console.log('✅ Registered in Firebase');
      } catch(e) { console.warn('Firebase registration error:', e); }
    }


