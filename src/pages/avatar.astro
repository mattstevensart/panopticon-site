---
import Layout from '../layouts/Layout.astro';
---

<Layout title="INTAKE PROCESSING">

  <!-- Returning user landing screen -->
  <div id="returning-landing" style="display: none;">
    <div style="min-height: 60vh; display: flex; align-items: center; justify-content: center;">
      <div style="text-align: center; max-width: 480px; padding: 40px 24px;">
        <div style="width: 120px; height: 120px; margin: 0 auto 24px; border: 3px solid rgb(140, 64, 255); overflow: hidden;">
          <img id="landing-avatar-img" src="" alt="Current avatar" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        <p style="font-family: 'Orbitron'; color: rgb(140, 64, 255); font-size: 14px; letter-spacing: 3px; margin-bottom: 4px;">INMATE <span id="landing-name"></span></p>
        <p style="font-family: 'Electrolize'; color: rgb(92, 87, 111); font-size: 12px; letter-spacing: 2px; margin-bottom: 32px;">ALREADY PROCESSED</p>
        <div style="display: flex; flex-direction: column; gap: 12px; align-items: center;">
          <button id="landing-new-btn" style="width: 280px; padding: 14px 24px; background: rgb(26, 224, 194); border: 2px solid rgb(26, 224, 194); color: rgb(10, 10, 15); font-family: 'Electrolize'; font-size: 14px; font-weight: bold; cursor: pointer; letter-spacing: 2px; transition: all 0.2s;">
            CREATE ANOTHER AVATAR →
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Welcome notice for first-time visitors -->
  <div id="welcome-notice" style="display: none; min-height: 80vh; background: rgb(10, 10, 15); display: none; align-items: center; justify-content: center;">
    <div style="max-width: 540px; width: 92%; padding: 48px 36px; text-align: center;">
      <!-- Panopticon eye icon -->
      <div style="font-size: 48px; margin-bottom: 24px; filter: drop-shadow(0 0 20px rgba(140, 64, 255, 0.4));">👁</div>
      <h2 style="font-family: 'Orbitron'; color: rgb(214, 214, 224); font-size: 22px; font-weight: bold; letter-spacing: 4px; margin-bottom: 28px; text-shadow: 0 0 20px rgba(140, 64, 255, 0.3);">AVATAR CREATION</h2>
      <div style="background: rgba(23, 23, 33, 0.8); border: 1px solid rgba(140, 64, 255, 0.25); padding: 28px 24px; margin-bottom: 32px; text-align: left;">
        <p style="font-family: 'Exo 2', sans-serif; color: rgb(214, 214, 224); font-size: 15px; line-height: 1.7; margin: 0;">
          Create a character in the world of Panopticon! This avatar will be yours. Create multiple alter inmates. The saved image will be your passport into more content including maps, scripts, character bios, and lore building. This will also provide special perks as Panopticon rolls out.
        </p>
        <p style="font-family: 'Exo 2', sans-serif; color: rgb(26, 224, 194); font-size: 15px; line-height: 1.7; margin: 20px 0 0 0;">
          But for now, make a character, scan it in as your ID, and be admitted into the world of Panopticon.
        </p>
      </div>
      <button id="welcome-start-btn" style="padding: 16px 40px; background: transparent; border: 2px solid rgb(26, 224, 194); color: rgb(26, 224, 194); font-family: 'Orbitron'; font-size: 15px; font-weight: bold; letter-spacing: 3px; cursor: pointer; transition: all 0.3s; text-shadow: 0 0 10px rgba(26, 224, 194, 0.3);">
        CREATE AN AVATAR →
      </button>
    </div>
  </div>

  <div id="avatar-creator-container" class="w-full bg-p-root">
    <!-- SVG filter for concrete texture (zero-size, invisible) -->
    <svg width="0" height="0" style="position: absolute;">
      <defs>
        <filter id="concrete-texture" x="0%" y="0%" width="100%" height="100%">
          <!-- Coarse pitting -->
          <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="6" seed="3" result="noise1" />
          <feColorMatrix type="saturate" values="0" in="noise1" result="gray1" />
          <!-- Fine grain -->
          <feTurbulence type="fractalNoise" baseFrequency="1.8" numOctaves="4" seed="7" result="noise2" />
          <feColorMatrix type="saturate" values="0" in="noise2" result="gray2" />
          <!-- Blend coarse + fine -->
          <feBlend in="gray1" in2="gray2" mode="multiply" result="combined" />
          <!-- Displacement for surface irregularity -->
          <feDisplacementMap in="SourceGraphic" in2="combined" scale="3" xChannelSelector="R" yChannelSelector="G" result="displaced" />
          <!-- Composite the texture -->
          <feComposite in="displaced" in2="SourceGraphic" operator="in" />
        </filter>
        <!-- Scar/crack lines -->
        <filter id="concrete-scars" x="0%" y="0%" width="100%" height="100%">
          <feTurbulence type="turbulence" baseFrequency="0.02 0.15" numOctaves="3" seed="42" result="cracks" />
          <feColorMatrix type="saturate" values="0" in="cracks" result="graycrack" />
          <feComponentTransfer in="graycrack" result="harshcrack">
            <feFuncR type="discrete" tableValues="0 0 0 0 0 0 0.12 0.08" />
            <feFuncG type="discrete" tableValues="0 0 0 0 0 0 0.12 0.08" />
            <feFuncB type="discrete" tableValues="0 0 0 0 0 0 0.12 0.08" />
          </feComponentTransfer>
          <feBlend in="SourceGraphic" in2="harshcrack" mode="screen" />
        </filter>
      </defs>
    </svg>

    <!-- Main creator viewport -->
    <div id="creator-main" class="flex justify-center items-start py-8 px-4">
      <div class="concrete-frame" id="desktop-concrete-frame">
        <!-- Corner bolts -->
        <span class="corner-bolt" style="top: 6px; left: 6px;"></span>
        <span class="corner-bolt" style="top: 6px; right: 6px;"></span>
        <span class="corner-bolt" style="bottom: 6px; left: 6px;"></span>
        <span class="corner-bolt" style="bottom: 6px; right: 6px;"></span>
        <!-- Midpoint bolts -->
        <span class="corner-bolt bolt-sm" style="top: 6px; left: 50%; transform: translateX(-50%);"></span>
        <span class="corner-bolt bolt-sm" style="bottom: 6px; left: 50%; transform: translateX(-50%);"></span>
        <!-- Stencil marking -->
        <span class="stencil-mark" style="bottom: 5px; left: 50%; transform: translateX(-50%);">PANOPTICON INTAKE TERMINAL</span>
        <!-- Hazard stripes on title bar edges -->
        <span class="hazard-stripe hazard-left"></span>
        <span class="hazard-stripe hazard-right"></span>

      <div id="creator-viewport" style="width: 1280px; height: 840px; transform-origin: top center; position: relative;">

        <!-- Title bar -->
        <div id="title-bar" style="position: absolute; top: 0; left: 0; width: 100%; height: 84px; background: rgb(15, 15, 23); border-left: 5px solid rgb(230, 38, 26); border-right: 5px solid rgb(26, 224, 194); display: flex; align-items: center; justify-content: space-between; padding: 0 16px; box-sizing: border-box; z-index: 10; overflow: hidden;">
          <img id="logo-img" src="/avatar-assets/Panopticon%20title%20chrome.png" style="height: 70px; width: auto; position: relative; z-index: 2;" alt="Panopticon" />
          <!-- EKG heartbeat line -->
          <canvas id="ekg-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; mask-image: linear-gradient(to right, transparent 0%, black 25%, black 55%, transparent 75%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 25%, black 55%, transparent 75%);"></canvas>
          <div style="display: flex; align-items: baseline; gap: 12px; position: relative; z-index: 2;">
            <span style="color: rgb(56, 140, 255); font-family: 'Electrolize'; font-size: 18px;">INTAKE</span>
            <span id="title-pulse" style="color: rgb(140, 64, 255); font-family: 'Orbitron'; font-size: 14px; font-weight: bold;">ASSESSMENT AND CLASSIFICATION SYSTEM</span>
          </div>
        </div>

        <!-- Content area (below title bar) -->
        <div style="position: absolute; top: 84px; left: 0; width: 100%; height: calc(100% - 84px - 56px); display: flex; gap: 0;">

          <!-- Canvas area (left) -->
          <div id="canvas-wrapper" style="position: relative; width: 700px; height: 100%; background: rgb(10, 10, 15); border: 2px solid rgb(56, 140, 255); overflow: hidden;">
            <canvas id="preview-canvas" width="700" height="700" style="display: block; width: 100%; height: 100%;"></canvas>

            <!-- Completion flash overlay (pointer-events: none so it never blocks interaction) -->
            <div id="canvas-complete-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 50; display: none;">
              <div id="canvas-flash-bg"></div>
              <div class="flash-ring" style="animation-delay: 0s;"></div>
              <div class="flash-ring" style="animation-delay: 0.2s;"></div>
              <div class="flash-ring" style="animation-delay: 0.4s;"></div>
            </div>

            <!-- Intro overlay -->
            <div id="intro-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10, 10, 15, 0.97); display: flex; align-items: center; justify-content: center; z-index: 1000;">
              <div id="intro-text" style="text-align: center; font-family: 'Orbitron'; line-height: 1.4;">
                <div id="intro-line-1" class="intro-line" style="opacity: 0; margin: 18px 0; font-size: 32px; font-weight: bold; color: rgb(214, 214, 224); text-shadow: 0 0 20px rgba(214, 214, 224, 0.3); transform: scale(0.9); transition: opacity 0.8s, transform 0.8s, text-shadow 0.8s, color 1.5s;">WELCOME TO THE PANOPTICON.</div>
                <div id="intro-line-2" class="intro-line" style="opacity: 0; margin: 18px 0; font-size: 28px; font-weight: bold; color: rgb(180, 140, 255); text-shadow: 0 0 20px rgba(140, 64, 255, 0.3); transform: scale(0.9); transition: opacity 0.8s, transform 0.8s, text-shadow 0.8s;">CLASSIFICATION INITIATING.</div>
                <div id="intro-line-3" class="intro-line" style="opacity: 0; margin: 18px 0; font-size: 24px; font-weight: bold; color: rgb(140, 64, 255); text-shadow: 0 0 30px rgba(140, 64, 255, 0.5); transform: scale(0.9); transition: opacity 0.8s, transform 0.8s, text-shadow 0.8s;">INTAKE AUTHORIZED</div>
                <div id="intro-line-4" class="intro-line" style="opacity: 0; margin: 24px 0 0; font-size: 18px; font-weight: bold; color: rgb(26, 224, 194); text-shadow: 0 0 20px rgba(26, 224, 194, 0.4); transform: scale(0.9); transition: opacity 0.6s, transform 0.6s;">SELECT FEATURES NOW.</div>
              </div>
            </div>
          </div>

          <!-- Right panel -->
          <div id="right-panel" style="position: relative; width: 580px; height: 100%; background: rgb(23, 23, 33); display: flex; border: 2px solid rgb(56, 140, 255); border-left: none;">

            <!-- Category list (left side) -->
            <div id="category-list" style="width: 160px; background: rgb(15, 15, 23); border-right: 1px solid rgb(56, 140, 255); overflow-y: auto; padding: 8px 0; max-height: 100%;">
              <!-- Categories injected by JS -->
            </div>

            <!-- Item grid (right side) -->
            <div id="item-grid-area" style="flex: 1; padding: 12px; overflow-y: auto; background: rgb(23, 23, 33); max-height: 100%;">
              <!-- Items injected by JS -->
            </div>
          </div>
        </div>

        <!-- Bottom action bar -->
        <div id="action-bar" style="position: absolute; bottom: 0; left: 0; width: 100%; height: 56px; background: rgb(23, 23, 33); border-top: 1px solid rgb(56, 140, 255); display: flex; align-items: center; justify-content: flex-end; gap: 10px; padding: 0 16px; box-sizing: border-box; z-index: 10;">
          <button id="reset-btn" class="action-button action-button-reset">RESET</button>
          <button id="name-btn" class="action-button action-button-glow" style="display: none;">NAME INMATE</button>
          <button id="id-btn" class="action-button action-button-glow" style="display: none;">GENERATE ID</button>
          <button id="save-btn" class="action-button action-button-glow" style="display: none;">SAVE PNG</button>
        </div>
      </div>
      </div><!-- /.concrete-frame desktop -->
    </div>

    <!-- Mobile creator (stacked layout, hidden on desktop) -->
    <div id="mobile-creator" style="display: none; width: 100%; background: rgb(10, 10, 15);">
      <div class="concrete-frame concrete-frame-mobile" id="mobile-concrete-frame">
        <!-- Corner bolts -->
        <span class="corner-bolt" style="top: 4px; left: 4px;"></span>
        <span class="corner-bolt" style="top: 4px; right: 4px;"></span>
        <span class="corner-bolt" style="bottom: 4px; left: 4px;"></span>
        <span class="corner-bolt" style="bottom: 4px; right: 4px;"></span>
        <span class="stencil-mark" style="top: 3px; left: 50%; transform: translateX(-50%); font-size: 6px;">INTAKE TERMINAL</span>

      <!-- Mobile canvas -->
      <div id="mobile-canvas-wrapper" style="width: 100%; position: relative; border-bottom: 2px solid rgb(56, 140, 255); display: flex; justify-content: center; background: rgb(10, 10, 15); overflow: hidden;">
        <canvas id="mobile-canvas" width="700" height="700" style="display: block; width: 100%; max-width: 500px; height: auto; background: rgb(10, 10, 15);"></canvas>
        <div id="mobile-canvas-complete-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 50; display: none;">
          <div class="canvas-flash-bg-m"></div>
          <div class="flash-ring" style="animation-delay: 0s;"></div>
          <div class="flash-ring" style="animation-delay: 0.2s;"></div>
          <div class="flash-ring" style="animation-delay: 0.4s;"></div>
        </div>
      </div>
      <!-- Mobile action bar (directly under avatar) -->
      <div id="mobile-action-bar" style="padding: 8px; background: rgb(23, 23, 33); border-bottom: 1px solid rgb(56, 140, 255); display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
        <button id="mobile-reset-btn" class="action-button action-button-reset">RESET</button>
        <button id="mobile-name-btn" class="action-button action-button-glow" style="display: none;">NAME INMATE</button>
        <button id="mobile-id-btn" class="action-button action-button-glow" style="display: none;">GENERATE ID</button>
        <button id="mobile-save-btn" class="action-button action-button-glow" style="display: none;">SAVE PNG</button>
      </div>
      <!-- Mobile categories (horizontal scroll) -->
      <div id="mobile-categories" style="display: flex; overflow-x: auto; background: rgb(15, 15, 23); border-bottom: 1px solid rgb(56, 140, 255); padding: 4px 0; gap: 0; -webkit-overflow-scrolling: touch;">
        <!-- Injected by JS -->
      </div>
      <!-- Mobile item grid -->
      <div id="mobile-items" style="padding: 8px; background: rgb(23, 23, 33); min-height: 200px;">
        <!-- Injected by JS -->
      </div>
      </div><!-- /.concrete-frame mobile -->
    </div>

    <!-- Name modal (hidden initially) -->
    <div id="name-modal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); z-index: 2000; align-items: center; justify-content: center;">
      <div style="background: rgb(23, 23, 33); border: 2px solid rgb(56, 140, 255); padding: 24px; width: 400px; max-width: 90vw; font-family: 'Exo 2';">
        <div style="color: rgb(214, 214, 224); font-family: 'Orbitron'; font-size: 16px; margin-bottom: 8px;">IDENTIFY SUBJECT</div>
        <div style="color: rgb(92, 87, 111); font-family: 'Electrolize'; font-size: 12px; margin-bottom: 16px;">ENTER INMATE DESIGNATION</div>
        <input id="name-input" type="text" maxlength="20" style="width: 100%; padding: 8px; background: rgb(51, 51, 66); border: 1px solid rgb(56, 140, 255); color: rgb(214, 214, 224); font-family: 'Electrolize'; box-sizing: border-box; margin-bottom: 16px;" placeholder="Enter name..." />
        <div style="display: flex; gap: 8px; justify-content: flex-end;">
          <button id="name-cancel-btn" class="action-button">CANCEL</button>
          <button id="name-confirm-btn" class="action-button" style="background: rgb(56, 140, 255); color: rgb(10, 10, 15);">CONFIRM</button>
        </div>
      </div>
    </div>

    <!-- Email registration modal (appears after PNG save) -->
    <div id="email-modal" style="display: none; position: fixed; inset: 0; z-index: 2500; background: rgba(10, 10, 15, 0.92); align-items: center; justify-content: center;">
      <div style="width: 480px; max-width: 92vw; background: rgb(23, 23, 33); border: 2px solid rgb(140, 64, 255); padding: 32px 32px 24px; box-shadow: 0 0 40px rgba(140, 64, 255, 0.2), 0 0 80px rgba(140, 64, 255, 0.08);">
        <div style="color: rgb(140, 64, 255); font-family: 'Orbitron'; font-size: 14px; letter-spacing: 3px; margin-bottom: 12px;">REGISTER YOUR INMATE</div>
        <div style="color: rgb(214, 214, 224); font-family: 'Exo 2', sans-serif; font-size: 14px; line-height: 1.7; margin-bottom: 12px;">
          Enter your email to lock in your avatar and get included on the <span style="color: rgb(26, 224, 194);">thank you page</span> of the book.
        </div>
        <div style="color: rgb(26, 224, 194); font-family: 'Electrolize'; font-size: 11px; letter-spacing: 1px; margin-bottom: 20px; padding: 8px 12px; border: 1px solid rgba(26, 224, 194, 0.2); background: rgba(26, 224, 194, 0.04);">
          YOUR EMAIL GETS YOUR AVATAR IN THE PRINTED BOOK + EXTRA LOOT IN YOUR ORDER
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <input id="email-input" type="email" placeholder="ENTER EMAIL" style="flex: 1; min-width: 200px; padding: 12px 14px; background: rgb(10, 10, 15); border: 2px solid rgb(92, 87, 111); color: rgb(214, 214, 224); font-family: 'Electrolize'; font-size: 14px; letter-spacing: 1px; outline: none;" />
          <button id="email-submit-btn" style="padding: 12px 20px; background: rgb(26, 224, 194); border: 2px solid rgb(26, 224, 194); color: rgb(10, 10, 15); font-family: 'Electrolize'; font-size: 14px; font-weight: bold; cursor: pointer; letter-spacing: 1px; white-space: nowrap;">COUNT ME IN →</button>
        </div>
        <div id="email-error" style="display: none; color: rgb(230, 38, 26); font-family: 'Electrolize'; font-size: 12px; margin-top: 8px;"></div>
        <div id="email-success" style="display: none; color: rgb(26, 224, 194); font-family: 'Electrolize'; font-size: 13px; margin-top: 12px; line-height: 1.6;"></div>
        <button id="email-skip-btn" style="display: block; margin-top: 16px; background: none; border: none; color: rgb(92, 87, 111); font-family: 'Electrolize'; font-size: 12px; letter-spacing: 2px; cursor: pointer; padding: 4px 0; transition: color 0.2s;">SKIP FOR NOW</button>
      </div>
    </div>

    <!-- Post-save message box (hidden initially) -->
    <div id="post-save-box" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 520px; background: rgb(23, 23, 33); border: 3px solid rgb(26, 224, 194); padding: 36px 40px; z-index: 2000; font-family: 'Exo 2'; max-width: 92vw; box-shadow: 0 0 40px rgba(26, 224, 194, 0.4), 0 0 80px rgba(26, 224, 194, 0.15); text-align: center;">
      <div id="post-save-text" style="color: rgb(214, 214, 224); font-size: 16px; line-height: 2.2; margin-bottom: 28px; white-space: pre-wrap; font-family: 'Electrolize';"></div>
      <a id="scan-btn" href="/scan?auto=1" style="display: inline-block; padding: 18px 40px; background: rgb(56, 140, 255); border: 3px solid rgb(56, 140, 255); color: rgb(10, 10, 15); font-family: 'Electrolize'; font-size: 18px; font-weight: bold; cursor: pointer; text-decoration: none; letter-spacing: 2px; text-align: center; box-shadow: 0 0 20px rgba(56, 140, 255, 0.4), 0 0 40px rgba(56, 140, 255, 0.15); animation: scan-btn-pulse 2s ease-in-out infinite;">SCAN INTO PANOPTICON →</a>
    </div>
  </div>

  <style is:global>
    /* ── Concrete Prison Frame ── */
    .concrete-frame {
      position: relative;
      padding: 18px;
      background:
        /* Base concrete color */
        linear-gradient(135deg, #3a3a3e 0%, #2e2e32 20%, #353538 40%, #2c2c30 60%, #333336 80%, #2a2a2e 100%);
      border: 2px solid #1a1a1e;
      box-shadow:
        inset 0 2px 4px rgba(255,255,255,0.06),
        inset 0 -2px 4px rgba(0,0,0,0.4),
        0 4px 20px rgba(0,0,0,0.6),
        0 0 0 1px rgba(0,0,0,0.8);
      overflow: visible;
    }
    /* Concrete surface texture overlay via ::before */
    .concrete-frame::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        /* Speckle layer */
        radial-gradient(circle 1px at 15% 25%, rgba(0,0,0,0.35) 0%, transparent 100%),
        radial-gradient(circle 1px at 72% 18%, rgba(0,0,0,0.3) 0%, transparent 100%),
        radial-gradient(circle 2px at 35% 65%, rgba(0,0,0,0.25) 0%, transparent 100%),
        radial-gradient(circle 1px at 85% 42%, rgba(0,0,0,0.35) 0%, transparent 100%),
        radial-gradient(circle 1.5px at 48% 88%, rgba(0,0,0,0.3) 0%, transparent 100%),
        radial-gradient(circle 1px at 8% 72%, rgba(0,0,0,0.25) 0%, transparent 100%),
        radial-gradient(circle 2px at 92% 78%, rgba(0,0,0,0.3) 0%, transparent 100%),
        radial-gradient(circle 1px at 58% 12%, rgba(0,0,0,0.2) 0%, transparent 100%),
        /* Stain patches */
        radial-gradient(ellipse 40px 25px at 20% 30%, rgba(0,0,0,0.12) 0%, transparent 100%),
        radial-gradient(ellipse 30px 50px at 75% 60%, rgba(0,0,0,0.1) 0%, transparent 100%),
        radial-gradient(ellipse 50px 20px at 50% 85%, rgba(0,0,0,0.08) 0%, transparent 100%),
        /* Subtle crack/score lines */
        linear-gradient(172deg, transparent 30%, rgba(0,0,0,0.15) 30.2%, transparent 30.4%),
        linear-gradient(95deg, transparent 55%, rgba(0,0,0,0.1) 55.1%, transparent 55.3%),
        linear-gradient(140deg, transparent 70%, rgba(0,0,0,0.12) 70.15%, transparent 70.3%);
      pointer-events: none;
      z-index: 0;
      filter: url(#concrete-texture);
    }
    /* Worn edge via ::after — top & bottom scuffed highlight */
    .concrete-frame::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to bottom,
          rgba(255,255,255,0.07) 0%,
          transparent 3%,
          transparent 97%,
          rgba(0,0,0,0.15) 100%
        ),
        linear-gradient(to right,
          rgba(0,0,0,0.1) 0%,
          transparent 2%,
          transparent 98%,
          rgba(0,0,0,0.1) 100%
        );
      pointer-events: none;
      z-index: 0;
    }

    /* Corner bolts */
    .corner-bolt {
      position: absolute;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background:
        radial-gradient(circle at 40% 35%, #5a5a5e 0%, #3a3a3e 40%, #252528 70%, #1a1a1e 100%);
      box-shadow:
        inset 0 1px 2px rgba(255,255,255,0.15),
        inset 0 -1px 2px rgba(0,0,0,0.5),
        0 1px 3px rgba(0,0,0,0.6);
      z-index: 1;
    }
    .corner-bolt::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 8px;
      height: 1.5px;
      background: rgba(0,0,0,0.5);
      transform: translate(-50%, -50%) rotate(35deg);
      border-radius: 1px;
    }
    .corner-bolt::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 8px;
      height: 1.5px;
      background: rgba(0,0,0,0.5);
      transform: translate(-50%, -50%) rotate(-55deg);
      border-radius: 1px;
    }
    .bolt-sm {
      width: 10px;
      height: 10px;
    }

    /* Stencil marking */
    .stencil-mark {
      position: absolute;
      font-family: 'Orbitron', monospace;
      font-size: 8px;
      letter-spacing: 4px;
      color: rgba(0,0,0,0.3);
