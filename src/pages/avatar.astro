        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          errorEl.textContent = 'SIGNAL NOT RECOGNIZED. ENTER A VALID EMAIL.';
          errorEl.style.display = 'block';
          input.style.borderColor = 'rgb(230, 38, 26)';
