            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              api_key: '2eFPMdkmtVc32GYBkRzBww',
              email: email,
              fields: {
                inmate_name: charName?.toUpperCase() || '',
                inmate_id: idCode?.toUpperCase() || ''
              }
            })
          });

          if (!resp.ok) throw new Error('Registration failed');

          // Store email locally
          localStorage.setItem('panopticon_inmate_email', email);

          // Auto-register in Firebase for earlybird campaign
          const thumbData = localStorage.getItem('panopticon_avatar_thumb') || '';
          const tokVal = localStorage.getItem('panopticon_inmate_tok') || idCode || '';
          registerInFirebase(email, charName?.toUpperCase(), idCode?.toUpperCase(), tokVal, thumbData);

          // Show success, then transition to post-save
