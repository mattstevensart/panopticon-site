    let currentUnlockStage = 0;
    let selections = {};
    let charName = '';
    let idCode = '';
    let completionFlashPlayed = false;
    let introCompleted = false;
    const imageCache = {};

    function init() {
      // Check if returning user (has completed intake before)
      const urlParams = new URLSearchParams(window.location.search);
      const forceNew = urlParams.get('new') === '1';
      const hasExistingAvatar = localStorage.getItem('panopticon_avatar_created') === 'true';

      if (hasExistingAvatar && !forceNew) {
        // Show returning user landing screen
        const landing = document.getElementById('returning-landing');
        const creator = document.getElementById('avatar-creator-container');
        const landingImg = document.getElementById('landing-avatar-img');
        const landingName = document.getElementById('landing-name');

        const avatarThumb = localStorage.getItem('panopticon_avatar_thumb');
        const inmateName = localStorage.getItem('panopticon_inmate_name');

        if (landingImg && avatarThumb) landingImg.src = avatarThumb;
        if (landingName) landingName.textContent = inmateName || 'UNKNOWN';

        if (landing) landing.style.display = 'block';
        if (creator) creator.style.display = 'none';

        // "Create another avatar" — reset state and start fresh
        document.getElementById('landing-new-btn')?.addEventListener('click', () => {
          localStorage.removeItem('panopticon_avatar_created');
          localStorage.removeItem('panopticon_intake_complete');
          localStorage.removeItem('panopticon_avatar_thumb');
          localStorage.removeItem('panopticon_inmate_name');
          localStorage.removeItem('panopticon_inmate_id');
          localStorage.removeItem('panopticon_inmate_tok');
          localStorage.removeItem('panopticon_inmate_gender');
          localStorage.removeItem('panopticon_inmate_race');
          localStorage.removeItem('panopticon_inmate_nutri');
          localStorage.removeItem('panopticon_inmate_email');
          if (landing) landing.style.display = 'none';
          if (creator) creator.style.display = 'block';
          launchCreator();
        });


        return;
      }

      // If ?new=1, clean the URL and go straight to creator
      if (forceNew) {
        window.history.replaceState({}, '', '/avatar');
        launchCreator();
        return;
      }

      // First-time visitor — show welcome notice
      const welcome = document.getElementById('welcome-notice');
      const creator = document.getElementById('avatar-creator-container');
      if (welcome) {
        welcome.style.display = 'flex';
        if (creator) creator.style.display = 'none';

        const startBtn = document.getElementById('welcome-start-btn');
        if (startBtn) {
          startBtn.addEventListener('mouseenter', () => {
            startBtn.style.background = 'rgba(26, 224, 194, 0.12)';
            startBtn.style.boxShadow = '0 0 30px rgba(26, 224, 194, 0.2), inset 0 0 20px rgba(26, 224, 194, 0.05)';
          });
          startBtn.addEventListener('mouseleave', () => {
            startBtn.style.background = 'transparent';
            startBtn.style.boxShadow = 'none';
          });
          startBtn.addEventListener('click', () => {
            welcome.style.opacity = '0';
            welcome.style.transition = 'opacity 0.4s ease';
            setTimeout(() => {
              welcome.style.display = 'none';
              if (creator) creator.style.display = 'block';
              launchCreator();
            }, 400);
          });
        }
        return;
      }

      launchCreator();
    }

    function launchCreator() {
      buildCategoryList();
      buildMobileCategories();
      initCanvas();
      startIntro();
      setupEventListeners();
      setupMobileEvents();
      handleResize();
      window.addEventListener('resize', handleResize);
      initEkg();
    }

    // ── EKG Heartbeat Animation ──
    function initEkg() {
      const canvas = document.getElementById('ekg-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const titleBar = document.getElementById('title-bar');

      function resize() {
        canvas.width = titleBar.offsetWidth;
        canvas.height = titleBar.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // EKG waveform shape — one heartbeat cycle as normalized y-values
      // flat → small bump (P wave) → flat → sharp spike up (QRS) → sharp dip → flat → small bump (T wave) → flat
      function ekgWave(t) {
        // t is 0..1 across one beat cycle
        if (t < 0.10) return 0;                                          // baseline
        if (t < 0.15) return Math.sin((t - 0.10) / 0.05 * Math.PI) * 0.12;  // P wave
        if (t < 0.20) return 0;                                          // baseline
        if (t < 0.23) return -((t - 0.20) / 0.03) * 0.15;               // Q dip
        if (t < 0.28) return -0.15 + ((t - 0.23) / 0.05) * 1.15;        // R spike up
        if (t < 0.33) return 1.0 - ((t - 0.28) / 0.05) * 1.35;          // S dip down
        if (t < 0.38) return -0.35 + ((t - 0.33) / 0.05) * 0.35;        // return to baseline
        if (t < 0.50) return 0;                                          // baseline
        if (t < 0.58) return Math.sin((t - 0.50) / 0.08 * Math.PI) * 0.18;  // T wave
        return 0;                                                        // baseline
      }

      let offset = 0;
      const speed = 1.5;        // pixels per frame
      const cycleWidth = 200;   // pixels per heartbeat cycle
      const amplitude = 22;     // max spike height in pixels

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const midY = canvas.height / 2;

        ctx.beginPath();
        ctx.strokeStyle = 'rgba(26, 224, 194, 0.6)';
        ctx.lineWidth = 1.5;
        ctx.shadowColor = 'rgba(26, 224, 194, 0.4)';
        ctx.shadowBlur = 6;

        for (let x = 0; x < canvas.width; x++) {
          const t = (((x + offset) % cycleWidth) + cycleWidth) % cycleWidth / cycleWidth;
          const y = midY - ekgWave(t) * amplitude;
          if (x === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();

        // Brighter leading edge dot
        const leadX = canvas.width * 0.55;
        const leadT = (((leadX + offset) % cycleWidth) + cycleWidth) % cycleWidth / cycleWidth;
        const leadY = midY - ekgWave(leadT) * amplitude;
        ctx.beginPath();
        ctx.arc(leadX, leadY, 2.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(26, 224, 194, 0.9)';
        ctx.shadowBlur = 10;
        ctx.fill();
        ctx.shadowBlur = 0;

        offset += speed;
        requestAnimationFrame(draw);
      }
      draw();
    }

    function buildMobileCategories() {
      const container = document.getElementById('mobile-categories');
      if (!container) return;
      container.innerHTML = '';
      CATEGORIES.forEach((cat, idx) => {
        const btn = document.createElement('button');
        btn.className = 'mobile-cat-btn';
        btn.textContent = cat.name;
        btn.dataset.index = idx;
        btn.addEventListener('click', () => {
          if (CATEGORIES[idx].unlockStage > currentUnlockStage) return;
          selectCategory(idx);
          syncMobileItems();
          // Highlight active
          container.querySelectorAll('.mobile-cat-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        });
        if (cat.unlockStage > currentUnlockStage) btn.classList.add('locked');
        container.appendChild(btn);
      });
    }

    function syncMobileItems() {
      const mobileItems = document.getElementById('mobile-items');
      const desktopItems = document.getElementById('item-grid-area');
      if (!mobileItems || !desktopItems) return;
      mobileItems.innerHTML = desktopItems.innerHTML;
      // Re-attach click handlers to mobile clones
      mobileItems.querySelectorAll('.item-thumbnail').forEach(btn => {
        btn.addEventListener('click', () => {
          const itemPath = btn.dataset.itemPath;
          const catIdx = btn.dataset.categoryIdx;
          // Find matching button in desktop grid and click it
          let desktopBtn;
          if (itemPath) {
            desktopBtn = desktopItems.querySelector(`[data-item-path="${CSS.escape(itemPath)}"]`);
          }
          if (!desktopBtn && catIdx !== undefined) {
            desktopBtn = desktopItems.querySelector(`[data-category-idx="${catIdx}"]`);
          }
          if (desktopBtn) desktopBtn.click();
          // Sync after selection
          setTimeout(() => { syncMobileCanvas(); syncMobileItems(); }, 100);
        });
      });
    }

    function syncMobileCanvas() {
      const mCanvas = document.getElementById('mobile-canvas');
      const dCanvas = document.getElementById('preview-canvas');
      if (!mCanvas || !dCanvas) return;
      const mCtx = mCanvas.getContext('2d');
      mCanvas.width = dCanvas.width;
      mCanvas.height = dCanvas.height;
      mCtx.drawImage(dCanvas, 0, 0);
    }

    function setupMobileEvents() {
      // Mobile reset
      document.getElementById('mobile-reset-btn')?.addEventListener('click', () => {
        document.getElementById('reset-btn')?.click();
        setTimeout(() => { syncMobileCanvas(); syncMobileItems(); }, 200);
      });
      // Mobile name
      document.getElementById('mobile-name-btn')?.addEventListener('click', () => {
        document.getElementById('name-btn')?.click();
      });
      // Mobile ID
      document.getElementById('mobile-id-btn')?.addEventListener('click', () => {
        document.getElementById('id-btn')?.click();
        setTimeout(syncMobileCanvas, 500);
      });
      // Mobile save
      document.getElementById('mobile-save-btn')?.addEventListener('click', () => {
        document.getElementById('save-btn')?.click();
      });
    }

    function handleResize() {
      const viewport = document.getElementById('creator-viewport');
      const mobileView = document.getElementById('mobile-creator');
      if (!viewport) return;
      const screenWidth = window.innerWidth;

      const creatorMain = document.getElementById('creator-main');
      const desktopFrame = document.getElementById('desktop-concrete-frame');

      // Mobile breakpoint: use stacked layout
      if (screenWidth < 768 && mobileView) {
        if (creatorMain) creatorMain.style.display = 'none';
        mobileView.style.display = 'block';
        // Sync canvas to mobile
        const mCanvas = document.getElementById('mobile-canvas');
        const dCanvas = document.getElementById('preview-canvas');
        if (mCanvas && dCanvas) {
          const mCtx = mCanvas.getContext('2d');
          mCanvas.width = dCanvas.width;
          mCanvas.height = dCanvas.height;
          mCtx.drawImage(dCanvas, 0, 0);
        }
      } else {
        if (mobileView) mobileView.style.display = 'none';
        if (creatorMain) creatorMain.style.display = 'flex';
        const containerWidth = creatorMain ? creatorMain.clientWidth : window.innerWidth;
        const framePad = 36; // 18px concrete padding each side
        const targetWidth = 1280;
        const targetHeight = 840;
        const availableWidth = containerWidth - framePad - 32;
        if (availableWidth < targetWidth) {
          const scale = availableWidth / targetWidth;
          viewport.style.transform = `scale(${scale})`;
          viewport.style.height = (targetHeight * scale) + 'px';
          if (desktopFrame) desktopFrame.style.height = (targetHeight * scale + 64) + 'px';
        } else {
          viewport.style.transform = 'scale(1)';
          viewport.style.height = targetHeight + 'px';
          if (desktopFrame) desktopFrame.style.height = '';
        }
      }
    }

    function buildCategoryList() {
      const list = document.getElementById('category-list');
      list.innerHTML = '';
      CATEGORIES.forEach((cat, idx) => {
        const btn = document.createElement('button');
        btn.className = 'category-btn';
        btn.dataset.index = idx;
        btn.textContent = cat.name;
        btn.addEventListener('click', () => selectCategory(idx));
        list.appendChild(btn);
      });
      selectCategory(0);
    }


    function selectCategory(idx) {
      const buttons = document.querySelectorAll('.category-btn');
      buttons.forEach((b, i) => {
        const isActive = i === idx;
        b.classList.toggle('active', isActive);
        const cat = CATEGORIES[i];
        const isUnlocked = cat.unlockStage <= currentUnlockStage;
        b.classList.toggle('locked', !isUnlocked);
        b.classList.toggle('has-selection', !!selections[cat.folder] || selections[cat.folder] === '__none__');
      });
      renderItemGrid(idx);
    }

    function renderItemGrid(catIdx) {
      const cat = CATEGORIES[catIdx];
      if (cat.unlockStage > currentUnlockStage) return;

      const gridArea = document.getElementById('item-grid-area');
      gridArea.innerHTML = '';

      let items = getItemsForCategory(cat);

      const gridDiv = document.createElement('div');
      gridDiv.className = 'item-grid';

      // Add NONE option first for optional categories (not Gender)
      if (cat.optional && cat.folder !== 'clothing/') {
        const noneWrapper = document.createElement('div');
        noneWrapper.className = 'item-wrapper';
        const noneBtn = document.createElement('button');
        noneBtn.className = 'item-thumbnail';
        noneBtn.dataset.categoryIdx = catIdx;
        noneBtn.dataset.itemPath = '__none__';
        noneBtn.style.borderStyle = 'dashed';
        noneBtn.style.display = 'flex';
        noneBtn.style.alignItems = 'center';
        noneBtn.style.justifyContent = 'center';
        noneBtn.style.aspectRatio = '1';
        noneBtn.style.lineHeight = 'normal';
        const isNoneSelected = selections[cat.folder] === '__none__';
        if (isNoneSelected) noneBtn.classList.add('confirmed');
        noneBtn.innerHTML = '<span style="font-family: Orbitron; font-size: 13px; font-weight: bold; color: rgb(214, 214, 224); letter-spacing: 2px;">NONE</span>';
        noneBtn.addEventListener('click', () => {
          selections[cat.folder] = '__none__';
          renderCanvas();
          selectCategory(catIdx);
        });
        noneWrapper.appendChild(noneBtn);
        gridDiv.appendChild(noneWrapper);
      }

      items.forEach(item => {
        const wrapper = document.createElement('div');
        wrapper.className = 'item-wrapper';

        const btn = document.createElement('button');
        btn.className = 'item-thumbnail';
        btn.dataset.categoryIdx = catIdx;
        btn.dataset.itemPath = item.full;
        btn.dataset.thumbPath = item.thumb;
        btn.dataset.label = item.label;

        const img = document.createElement('img');
        img.src = item.thumb;
        img.alt = item.label;
        img.loading = 'lazy';
        btn.appendChild(img);

        const isSelected = selections[cat.folder]?.full === item.full;
        if (isSelected) btn.classList.add('confirmed');

        btn.addEventListener('click', () => toggleSelection(catIdx, item));
        wrapper.appendChild(btn);

        // Only show labels for Gender category (MALE / FEMALE)
        if (cat.folder === 'clothing/') {
          const label = document.createElement('div');
          label.className = 'item-label';
          const isFemale = item.filename.toLowerCase().includes('female');
          label.textContent = isFemale ? 'FEMALE' : 'MALE';
          label.style.fontSize = '12px';
          label.style.fontFamily = 'Orbitron';
          label.style.fontWeight = 'bold';
          label.style.color = 'rgb(214, 214, 224)';
          wrapper.appendChild(label);
        }

        gridDiv.appendChild(wrapper);
      });

      gridArea.appendChild(gridDiv);
    }

    function encodePath(p) {
      return p.split('/').map(s => encodeURIComponent(s)).join('/');
    }

    function getItemsForCategory(cat) {
      let items = [];
      const manifest = ASSET_MANIFEST;
      const catFolder = cat.folder; // e.g. "clothing/", "heads/", "eyes/"

      manifest.forEach(path => {
        const webPath = path.replace(/^assets\//, '');

        // Strict startsWith match to avoid "eyes/" matching "female eyes/"
        if (webPath.startsWith(catFolder) || webPath.toLowerCase().startsWith(catFolder.toLowerCase())) {
          const parts = webPath.split('/');
          const filename = parts[parts.length - 1];
          const filenameNoExt = filename.replace('.png', '');

          const fullPath = encodePath('/avatar-assets/' + webPath);
          const thumbPath = encodePath('/avatar-assets/_thumbs/' + webPath);

          items.push({
            full: fullPath,
            thumb: thumbPath,
            label: filenameNoExt,
            filename: filename
          });
        }
      });

      // Head gender filtering — show male heads for male, female heads for female
      if (cat.folder === 'heads/') {
        const clothingSel = selections['clothing/'];
        if (clothingSel) {
          const isFemale = clothingSel.filename.toLowerCase().includes('female');
          if (isFemale) {
            // Show only female heads (folders ending in _female)
            items = items.filter(item => item.full.includes('_female/'));
          } else {
            // Show only male heads (exclude _female folders)
            items = items.filter(item => !item.full.includes('_female/'));
          }
        }
        // If no gender selected yet, unlockStage prevents rendering anyway
      }

      // Ear color filtering — only show ears matching the selected head's skin color
      if (cat.folder === 'ears/' && selections['heads/']) {
        const headFilename = selections['heads/'].filename.toLowerCase().replace('.png', '');
        items = items.filter(item => {
          const earColor = item.filename.toLowerCase().replace('.png', '');
          return earColor === headFilename;
        });
      }

      // Female eyes merge into Eyes grid when female clothing selected
      if (cat.folder === 'eyes/' && selections['clothing/']?.filename.toLowerCase().includes('female')) {
        const femaleEyes = manifest.filter(p => p.startsWith('assets/female eyes/')).map(p => {
          const webPath = p.replace(/^assets\//, '');
          const parts = webPath.split('/');
          const filename = parts[parts.length - 1];
          const filenameNoExt = filename.replace('.png', '');
          return {
            full: encodePath('/avatar-assets/' + webPath),
            thumb: encodePath('/avatar-assets/_thumbs/' + webPath),
            label: filenameNoExt,
            filename: filename
          };
        });
        items = items.concat(femaleEyes);
      }

      // Female lips merge into Mouth grid when female clothing selected
      if (cat.folder === 'mouth/' && selections['clothing/']?.filename.toLowerCase().includes('female')) {
        const femaleLips = manifest.filter(p => p.startsWith('assets/female lips/')).map(p => {
          const webPath = p.replace(/^assets\//, '');
          const parts = webPath.split('/');
          const filename = parts[parts.length - 1];
          const filenameNoExt = filename.replace('.png', '');
          return {
            full: encodePath('/avatar-assets/' + webPath),
            thumb: encodePath('/avatar-assets/_thumbs/' + webPath),
            label: filenameNoExt,
            filename: filename
          };
        });
        items = items.concat(femaleLips);
      }

      return items;
    }

    function findNextCategory(currentIdx) {
      // First: find the next EMPTY unlocked category
      for (let i = currentIdx + 1; i < CATEGORIES.length; i++) {
        const cat = CATEGORIES[i];
        if (cat.unlockStage <= currentUnlockStage && !selections[cat.folder]) {
          return i;
        }
      }
      // Wrap around
      for (let i = 0; i < currentIdx; i++) {
        const cat = CATEGORIES[i];
        if (cat.unlockStage <= currentUnlockStage && !selections[cat.folder]) {
          return i;
        }
      }
      // If all filled, just go to next unlocked category (not empty)
      const nextIdx = currentIdx + 1;
      if (nextIdx < CATEGORIES.length && CATEGORIES[nextIdx].unlockStage <= currentUnlockStage) {
        return nextIdx;
      }
      return null;
    }

    function scrollMobileCategoryIntoView(idx) {
      const mobileContainer = document.getElementById('mobile-categories');
      if (!mobileContainer) return;
      const mobileBtns = mobileContainer.querySelectorAll('.mobile-cat-btn');
      mobileBtns.forEach(b => b.classList.remove('active', 'next-up'));
      if (mobileBtns[idx]) {
        mobileBtns[idx].classList.add('active');
        // Scroll into view with center alignment
        mobileBtns[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        // Pulse animation
        void mobileBtns[idx].offsetWidth;
        mobileBtns[idx].classList.add('next-up');
        mobileBtns[idx].addEventListener('animationend', () => mobileBtns[idx].classList.remove('next-up'), { once: true });
      }
    }

    function toggleSelection(catIdx, item) {
      const cat = CATEGORIES[catIdx];
      const folder = cat.folder;

      if (selections[folder]?.full === item.full) {
        selections[folder] = null;
      } else {
        selections[folder] = item;

        // If gender just changed, clear any existing head selection so the
        // correct male/female heads are shown fresh
        if (folder === 'clothing/') {
          selections['heads/'] = null;
        }

        updateUnlockStage();

        // Flash the category button 3× to confirm selection
        const catBtn = document.querySelector(`.category-btn[data-index="${catIdx}"]`);
        if (catBtn) {
          catBtn.classList.remove('just-selected');
          void catBtn.offsetWidth; // force reflow to restart animation
          catBtn.classList.add('just-selected');
          catBtn.addEventListener('animationend', () => catBtn.classList.remove('just-selected'), { once: true });
        }
      }

      renderCanvas();

      // Auto-advance to next category after making a selection
      if (selections[folder]) {
        const nextIdx = findNextCategory(catIdx);
        if (nextIdx !== null) {
          setTimeout(() => {
            selectCategory(nextIdx);
            syncMobileItems();
            scrollMobileCategoryIntoView(nextIdx);
          }, 350);
          return;
        }
      }
      selectCategory(catIdx);
    }

    function updateUnlockStage() {
      let faceFeatureCount = 0;
      const faceFeatures = ['eyes/', 'mouth/', 'noses/', 'eyebrows/'];
      faceFeatures.forEach(f => {
        if (selections[f]) faceFeatureCount++;
      });

      const genderSelected = !!selections['clothing/'];
      const headSelected = !!selections['heads/'];
      const hasHornsOrScars = !!selections['Horns/'] || !!selections['Scarz/'];

      if (genderSelected && headSelected) {
        if (faceFeatureCount >= 2) {
          if (hasHornsOrScars) {
            currentUnlockStage = 4;
          } else {
            currentUnlockStage = 3;
          }
        } else {
          currentUnlockStage = 2;
        }
      } else if (genderSelected) {
        currentUnlockStage = 1;
      } else {
        currentUnlockStage = 0;
      }

      // Show NAME INMATE when ALL categories have a selection
      const allSelected = CATEGORIES.every(cat => !!selections[cat.folder]);
      const nameBtn = document.getElementById('name-btn');
      if (nameBtn && !charName) {
        if (allSelected) {
          revealBtn('name-btn');
        } else {
          nameBtn.style.display = 'none';
        }
      }

      // Fire the completion burst the first time all categories are filled
      if (allSelected && !completionFlashPlayed) {
        completionFlashPlayed = true;
        triggerCompletionFlash();
      } else if (!allSelected) {
        completionFlashPlayed = false; // reset if user deselects something
      }

      // Sync mobile action buttons
      const mNameBtn = document.getElementById('mobile-name-btn');
      const mIdBtn = document.getElementById('mobile-id-btn');
      const mSaveBtn = document.getElementById('mobile-save-btn');
      if (mNameBtn) mNameBtn.style.display = document.getElementById('name-btn')?.style.display || 'none';
      if (mIdBtn) mIdBtn.style.display = document.getElementById('id-btn')?.style.display || 'none';
      if (mSaveBtn) mSaveBtn.style.display = document.getElementById('save-btn')?.style.display || 'none';

      // Sync mobile category locked/selection states
      const mobileCats = document.querySelectorAll('.mobile-cat-btn');
      mobileCats.forEach((btn, i) => {
        const cat = CATEGORIES[i];
        btn.classList.toggle('locked', cat.unlockStage > currentUnlockStage);
        btn.classList.toggle('has-selection', !!selections[cat.folder]);
      });
    }

    function initCanvas() {
      // Canvas is ready
    }

    async function renderCanvas(patchGlitch) {
      const canvas = document.getElementById('preview-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      ctx.fillStyle = 'rgb(10, 10, 15)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Build layers sorted by drawOrder
      const layers = [];
      CATEGORIES.forEach(cat => {
        const sel = selections[cat.folder];
        if (sel && sel !== '__none__') {
          layers.push({ order: cat.drawOrder, path: sel.full, catName: cat.name });
        }
      });
      layers.sort((a, b) => a.order - b.order);

      // Load all images first, then draw in order
      const loaded = await Promise.all(layers.map(async (layer) => {
        const img = await loadImage(layer.path);
        return { ...layer, img };
      }));

      // Draw HUD overlay
      const hudPath = encodePath('/avatar-assets/Intake HUD/HUD NEW.png');
      const hudImg = await loadImage(hudPath);
      let hudDrawn = false;

      for (const layer of loaded) {
        // Insert HUD before drawOrder 15 (Food)
        if (!hudDrawn && layer.order >= 15 && hudImg) {
          ctx.drawImage(hudImg, 0, 0, canvas.width, canvas.height);
          hudDrawn = true;
        }
        if (layer.img) {
          ctx.drawImage(layer.img, 0, 0, canvas.width, canvas.height);
        }
      }

      // If HUD hasn't been drawn yet (no layer with order >= 15), draw it on top
      if (!hudDrawn && hudImg) {
        ctx.drawImage(hudImg, 0, 0, canvas.width, canvas.height);
      }

      // Draw HUD text labels
      drawHudLabels(ctx);

      // Draw ID patch if generated
      if (idCode) {
        drawIdPatch(ctx, idCode, patchGlitch || null);
      }

      // Sync to mobile canvas if visible
      syncMobileCanvas();
    }

    function drawHudLabels(ctx) {
      // HUD label positions (canvas coords from Godot: lx=27, lw=146, y centers at 71, 127, 183)
      const lx = 27, lw = 146;
      const labels = [];

      // Gender
      const genderSel = selections['clothing/'];
      if (genderSel) {
        const isFemale = genderSel.filename.toLowerCase().includes('female');
        labels.push({ text: isFemale ? 'FEMALE' : 'MALE', y: 71 });
      }

      // Race (head style name — strip _female suffix for display)
      const headSel = selections['heads/'];
      if (headSel) {
        const parts = headSel.full.split('/');
        const styleName = (parts[parts.length - 2] || '').replace(/_female$/i, '');
        labels.push({ text: styleName.toUpperCase(), y: 127 });
      }

      // Nutri (food name)
      const foodSel = selections['Food/'];
      if (foodSel && foodSel !== '__none__') {
        labels.push({ text: foodSel.label.toUpperCase(), y: 183 });
      }

      ctx.save();
      ctx.font = 'bold 13px Orbitron';
      ctx.fillStyle = 'rgb(217, 64, 255)';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      labels.forEach(l => {
        ctx.fillText(l.text, lx + lw / 2, l.y);
      });
      ctx.restore();
    }

    function drawIdPatch(ctx, code, glitchOffset) {
      // Patch at chest position (Godot: PATCH_CX=462, PATCH_CY=596, PATCH_DISP=90)
      const cx = 462, cy = 596, r = 45;
      const gx = glitchOffset ? glitchOffset.x : 0;
      const gy = glitchOffset ? glitchOffset.y : 0;

      ctx.save();

      // Drop shadow (tight, slightly offset down-right)
      ctx.beginPath();
      ctx.arc(cx + 1.5, cy + 2, r + 1, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
      ctx.filter = 'blur(2px)';
      ctx.fill();
      ctx.filter = 'none';

      // Outer dark ring
      ctx.beginPath();
      ctx.arc(cx + gx, cy + gy, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgb(28, 28, 32)';
      ctx.fill();

      // Dark outer border
      ctx.beginPath();
      ctx.arc(cx + gx, cy + gy, r, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgb(12, 12, 15)';
      ctx.lineWidth = 8;
      ctx.stroke();

      // Light gray center
      ctx.beginPath();
      ctx.arc(cx + gx, cy + gy, r * 0.80, 0, Math.PI * 2);
      ctx.fillStyle = 'rgb(168, 168, 172)';
      ctx.fill();

      // Thin dark ring
      ctx.beginPath();
      ctx.arc(cx + gx, cy + gy, r * 0.80, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgb(85, 85, 92)';
      ctx.lineWidth = 2;
      ctx.stroke();

      // ID text
      ctx.font = 'bold ' + Math.round(r * 0.56) + 'px Orbitron';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      // Shadow
      ctx.fillStyle = 'rgba(30, 0, 50, 0.55)';
      ctx.fillText(code, cx + gx + 1, cy + gy + 1);
      // Main text
      ctx.fillStyle = 'rgb(100, 0, 140)';
      ctx.fillText(code, cx + gx, cy + gy);
      ctx.restore();
    }

    // Patch glitch — fires ONCE when patch first appears, then stops
    let patchGlitchTimer = null;
    function startPatchGlitch() {
      if (patchGlitchTimer) return;
      if (!idCode) return;
      // Fire immediately (tiny delay to let the initial render settle)
      patchGlitchTimer = setTimeout(async () => {
        const canvas = document.getElementById('preview-canvas');
        if (!canvas) { patchGlitchTimer = null; return; }
        // Quick burst of 3-5 glitch frames
        const burstCount = 3 + Math.floor(Math.random() * 3);
        for (let i = 0; i < burstCount; i++) {
          const ox = (Math.random() - 0.5) * 6;
          const oy = (Math.random() - 0.5) * 4;
          await renderCanvas({ x: ox, y: oy });
          await new Promise(r => setTimeout(r, 40 + Math.random() * 30));
        }
        // Settle back to normal
        await renderCanvas(null);
        patchGlitchTimer = null;
      }, 100);
    }

    function loadImage(path) {
      return new Promise((resolve) => {
        if (imageCache[path]) {
          resolve(imageCache[path]);
          return;
        }
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.src = path;
        img.onload = () => {
          imageCache[path] = img;
          resolve(img);
        };
        img.onerror = () => resolve(null);
      });
    }

    function startIntro() {
      if (introCompleted) return;

      const overlay = document.getElementById('intro-overlay');
      const line1 = document.getElementById('intro-line-1');
      const line2 = document.getElementById('intro-line-2');
      const line3 = document.getElementById('intro-line-3');
      const line4 = document.getElementById('intro-line-4');

      function showLine(el, delay) {
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'scale(1)';
          // Pulse glow after appearing
          setTimeout(() => {
            el.style.textShadow = el.style.textShadow.replace(/[\d.]+\)/g, '0.8)');
          }, 400);
          setTimeout(() => {
            el.style.textShadow = el.style.textShadow.replace(/[\d.]+\)/g, '0.4)');
          }, 800);
        }, delay);
      }

      // Line 1: white, fades in at 1s
      showLine(line1, 1000);
      // Shift line 1 from white toward violet after line 2 appears
      setTimeout(() => {
        line1.style.color = 'rgb(200, 180, 240)';
        line1.style.textShadow = '0 0 25px rgba(140, 64, 255, 0.4)';
      }, 3200);

      // Line 2: violet, fades in at 3s
      showLine(line2, 3000);

      // Line 3: "INTAKE AUTHORIZED" — glitch slam at 5.5s
      setTimeout(() => {
        // Quick glitch burst before stamp
        let glitchCount = 0;
        const glitchInterval = setInterval(() => {
          line3.style.opacity = '1';
          line3.style.transform = `scale(1.15) translate(${(Math.random()-0.5)*8}px, ${(Math.random()-0.5)*4}px)`;
          line3.style.color = glitchCount % 2 === 0 ? 'rgb(230, 38, 26)' : 'rgb(140, 64, 255)';
          glitchCount++;
          if (glitchCount > 5) {
            clearInterval(glitchInterval);
            // Final stamp — scale bounce
            line3.style.transform = 'scale(1.3)';
            line3.style.color = 'rgb(140, 64, 255)';
            line3.style.textShadow = '0 0 40px rgba(140, 64, 255, 0.8), 0 0 80px rgba(140, 64, 255, 0.4)';
            // Screen flash
            overlay.style.background = 'rgba(140, 64, 255, 0.15)';
            setTimeout(() => {
              line3.style.transform = 'scale(1)';
              overlay.style.background = 'rgba(10, 10, 15, 0.97)';
              line3.style.textShadow = '0 0 30px rgba(140, 64, 255, 0.5)';
            }, 200);
          }
        }, 50);
      }, 5500);

      // Line 4: "SELECT FEATURES NOW" — teal CTA fades in after stamp
      showLine(line4, 7000);

      // Fade out overlay
      setTimeout(() => {
        overlay.style.opacity = '0';
        overlay.style.transition = 'opacity 0.6s';
        setTimeout(() => {
          overlay.style.display = 'none';
          introCompleted = true;
        }, 600);
      }, 9500);
    }

    // Fire the completion burst behind the character — plays once per build session
    function triggerCompletionFlash() {
      ['canvas-complete-overlay', 'mobile-canvas-complete-overlay'].forEach(id => {
        const overlay = document.getElementById(id);
        if (!overlay) return;

        // Reset all animated children so the animation can restart cleanly
        overlay.querySelectorAll('#canvas-flash-bg, .canvas-flash-bg-m, .flash-ring').forEach(el => {
          el.style.animationName = 'none';
        });

        overlay.style.display = 'block';

        // Double rAF forces the browser to commit the "none" state before removing it
        requestAnimationFrame(() => requestAnimationFrame(() => {
          overlay.querySelectorAll('#canvas-flash-bg, .canvas-flash-bg-m, .flash-ring').forEach(el => {
            el.style.animationName = '';
          });
        }));

        // Hide overlay once the longest animation (ring 3 at 0.4s delay + 1.1s) is done
        setTimeout(() => { overlay.style.display = 'none'; }, 1700);
      });
    }

    // Reveal a button with the spring slide-in entrance animation
    function revealBtn(id) {
      const btn = document.getElementById(id);
      if (!btn || btn.style.display !== 'none') return; // skip if already visible
      btn.style.display = 'inline-block';
      btn.classList.remove('btn-entering');
      void btn.offsetWidth; // force reflow so animation restarts cleanly
      btn.classList.add('btn-entering');
      btn.addEventListener('animationend', () => btn.classList.remove('btn-entering'), { once: true });
    }

