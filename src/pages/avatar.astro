---
import Layout from '../layouts/Layout.astro';
---

<Layout title="INTAKE PROCESSING">
  <div id="avatar-creator-container" class="w-full bg-p-root">
    <!-- Main creator viewport -->
    <div id="creator-main" class="flex justify-center items-start py-8 px-4">
      <div id="creator-viewport" style="width: 1280px; height: 768px; transform-origin: top center; position: relative;">

        <!-- Title bar -->
        <div id="title-bar" style="position: absolute; top: 0; left: 0; width: 100%; height: 84px; background: rgb(15, 15, 23); border-left: 5px solid rgb(230, 38, 26); border-right: 5px solid rgb(26, 224, 194); display: flex; align-items: center; justify-content: space-between; padding: 0 16px; box-sizing: border-box; z-index: 10;">
          <img id="logo-img" src="/avatar-assets/Panopticon%20title%20chrome.png" style="height: 70px; width: auto;" alt="Panopticon" />
          <div style="display: flex; align-items: baseline; gap: 12px;">
            <span style="color: rgb(56, 140, 255); font-family: 'Electrolize'; font-size: 18px;">INTAKE</span>
            <span id="title-pulse" style="color: rgb(140, 64, 255); font-family: 'Orbitron'; font-size: 14px; font-weight: bold;">ASSESSMENT AND CLASSIFICATION SYSTEM</span>
          </div>
        </div>

        <!-- Content area (below title bar) -->
        <div style="position: absolute; top: 84px; left: 0; width: 100%; height: calc(100% - 84px - 40px); display: flex; gap: 0;">

          <!-- Canvas area (left) -->
          <div id="canvas-wrapper" style="position: relative; width: 700px; height: 100%; background: rgb(10, 10, 15); border: 2px solid rgb(56, 140, 255); overflow: hidden;">
            <canvas id="preview-canvas" width="700" height="684" style="display: block; width: 100%; height: auto;"></canvas>

            <!-- Intro overlay -->
            <div id="intro-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10, 10, 15, 0.95); display: flex; align-items: center; justify-content: center; z-index: 1000;">
              <div id="intro-text" style="text-align: center; color: rgb(214, 214, 224); font-family: 'Orbitron'; font-size: 20px; line-height: 2;">
                <div id="intro-line-1" style="opacity: 0; margin: 20px 0; transition: opacity 1s;">WELCOME TO THE PANOPTICON.</div>
                <div id="intro-line-2" style="opacity: 0; margin: 20px 0; transition: opacity 1s;">CLASSIFICATION INITIATING.</div>
                <div id="intro-line-3" style="opacity: 0; margin: 20px 0; color: rgb(26, 224, 194); transition: opacity 1s;">SELECT FEATURES NOW.</div>
              </div>
            </div>
          </div>

          <!-- Right panel -->
          <div id="right-panel" style="position: relative; width: 580px; height: 100%; background: rgb(23, 23, 33); display: flex; border: 2px solid rgb(56, 140, 255); border-left: none;">

            <!-- Category list (left side) -->
            <div id="category-list" style="width: 160px; background: rgb(15, 15, 23); border-right: 1px solid rgb(56, 140, 255); overflow-y: auto; padding: 8px 0; max-height: 100%;">
              <!-- Categories injected by JS -->
            </div>

            <!-- Item grid (right side) -->
            <div id="item-grid-area" style="flex: 1; padding: 12px; overflow-y: auto; background: rgb(23, 23, 33); max-height: 100%;">
              <!-- Items injected by JS -->
            </div>
          </div>
        </div>

        <!-- Bottom action bar -->
        <div id="action-bar" style="position: absolute; bottom: 0; left: 0; width: 100%; height: 40px; background: rgb(23, 23, 33); border-top: 1px solid rgb(56, 140, 255); display: flex; align-items: center; justify-content: flex-end; gap: 8px; padding: 0 12px; box-sizing: border-box; z-index: 10;">
          <button id="reset-btn" class="action-button">RESET</button>
          <button id="name-btn" class="action-button action-button-glow" style="display: none;">NAME INMATE</button>
          <button id="id-btn" class="action-button action-button-glow" style="display: none;">GENERATE ID</button>
          <button id="save-btn" class="action-button action-button-glow" style="display: none;">SAVE PNG</button>
        </div>
      </div>
    </div>

    <!-- Name modal (hidden initially) -->
    <div id="name-modal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); z-index: 2000; align-items: center; justify-content: center;">
      <div style="background: rgb(23, 23, 33); border: 2px solid rgb(56, 140, 255); padding: 24px; width: 400px; max-width: 90vw; font-family: 'Exo 2';">
        <div style="color: rgb(214, 214, 224); font-family: 'Orbitron'; font-size: 16px; margin-bottom: 8px;">IDENTIFY SUBJECT</div>
        <div style="color: rgb(92, 87, 111); font-family: 'Electrolize'; font-size: 12px; margin-bottom: 16px;">ENTER INMATE DESIGNATION</div>
        <input id="name-input" type="text" maxlength="20" style="width: 100%; padding: 8px; background: rgb(51, 51, 66); border: 1px solid rgb(56, 140, 255); color: rgb(214, 214, 224); font-family: 'Electrolize'; box-sizing: border-box; margin-bottom: 16px;" placeholder="Enter name..." />
        <div style="display: flex; gap: 8px; justify-content: flex-end;">
          <button id="name-cancel-btn" class="action-button">CANCEL</button>
          <button id="name-confirm-btn" class="action-button" style="background: rgb(56, 140, 255); color: rgb(10, 10, 15);">CONFIRM</button>
        </div>
      </div>
    </div>

    <!-- Post-save message box (hidden initially) -->
    <div id="post-save-box" style="position: fixed; bottom: 40px; right: 40px; width: 320px; background: rgb(23, 23, 33); border: 2px solid rgb(26, 224, 194); padding: 20px; z-index: 2000; font-family: 'Exo 2'; max-width: 90vw;">
      <div id="post-save-text" style="color: rgb(214, 214, 224); font-size: 12px; line-height: 1.8; margin-bottom: 16px; white-space: pre-wrap; font-family: 'Electrolize';"></div>
      <a id="scan-btn" href="/scan" style="display: inline-block; padding: 8px 12px; background: rgb(56, 140, 255); border: 1px solid rgb(56, 140, 255); color: rgb(10, 10, 15); font-family: 'Electrolize'; font-size: 11px; cursor: pointer; text-decoration: none;">SCAN INTO PANOPTICON →</a>
    </div>
  </div>

  <style is:global>
    @keyframes pulse-text {
      0%, 100% {
        color: rgb(140, 64, 255);
        text-shadow: 0 0 10px rgba(140, 64, 255, 0.5);
      }
      50% {
        color: rgb(217, 64, 255);
        text-shadow: 0 0 20px rgba(217, 64, 255, 0.8);
      }
    }

    #title-pulse {
      animation: pulse-text 1.5s infinite;
    }

    #avatar-creator-container {
      font-family: 'Exo 2', sans-serif;
    }

    #category-list {
      scrollbar-width: thin;
      scrollbar-color: rgb(56, 140, 255) rgb(23, 23, 33);
    }

    #category-list::-webkit-scrollbar {
      width: 6px;
    }

    #category-list::-webkit-scrollbar-track {
      background: rgb(23, 23, 33);
    }

    #category-list::-webkit-scrollbar-thumb {
      background: rgb(56, 140, 255);
      border-radius: 3px;
    }

    #item-grid-area {
      scrollbar-width: thin;
      scrollbar-color: rgb(56, 140, 255) rgb(23, 23, 33);
    }

    #item-grid-area::-webkit-scrollbar {
      width: 6px;
    }

    #item-grid-area::-webkit-scrollbar-track {
      background: rgb(23, 23, 33);
    }

    #item-grid-area::-webkit-scrollbar-thumb {
      background: rgb(56, 140, 255);
      border-radius: 3px;
    }

    .category-btn {
      width: 100%;
      padding: 12px 8px;
      background: rgb(51, 51, 66);
      border: none;
      border-left: 4px solid transparent;
      color: rgb(92, 87, 111);
      font-family: 'Orbitron';
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      cursor: pointer;
      text-align: left;
      transition: all 0.2s;
      box-sizing: border-box;
    }

    .category-btn:hover:not(.locked) {
      background: rgb(56, 56, 71);
      color: rgb(214, 214, 224);
      border-left-color: rgb(56, 140, 255);
    }

    .category-btn.active {
      background: rgb(56, 140, 255);
      color: rgb(10, 10, 15);
      border-left-color: rgb(26, 224, 194);
    }

    .category-btn.locked {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .category-btn.has-selection {
      color: rgb(56, 140, 255);
    }

    .category-btn.active.has-selection {
      color: rgb(10, 10, 15);
    }

    .item-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .item-wrapper {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .item-thumbnail {
      width: 100%;
      background: rgb(51, 51, 66);
      border: 2px solid rgb(92, 87, 111);
      cursor: pointer;
      transition: all 0.2s;
      overflow: hidden;
      padding: 0;
      display: block;
      line-height: 0;
    }

    .item-thumbnail img {
      width: 100%;
      height: auto;
      display: block;
      image-rendering: auto;
    }

    .item-thumbnail.preview {
      border-color: rgb(56, 140, 255);
      opacity: 0.7;
    }

    .item-thumbnail.confirmed {
      border-color: rgb(26, 224, 194);
      opacity: 1;
      background: rgb(10, 36, 15);
      box-shadow: 0 0 8px rgba(56, 235, 97, 0.4);
    }

    .item-thumbnail:hover:not(.disabled) {
      border-color: rgb(56, 140, 255);
    }

    .item-thumbnail.disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .item-label {
      font-size: 10px;
      color: rgb(92, 87, 111);
      text-align: center;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-family: 'Electrolize';
    }

    .action-button {
      padding: 6px 12px;
      background: rgb(51, 51, 66);
      border: 1px solid rgb(92, 87, 111);
      color: rgb(214, 214, 224);
      font-family: 'Electrolize';
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .action-button:hover {
      border-color: rgb(56, 140, 255);
      color: rgb(56, 140, 255);
    }

    .action-button-red {
      background: rgb(230, 38, 26);
      border-color: rgb(230, 38, 26);
    }

    @keyframes glow-green-pulse {
      0%, 100% {
        box-shadow: 0 0 8px 2px rgba(56, 235, 97, 0.4);
        border-color: rgb(56, 235, 97);
      }
      50% {
        box-shadow: 0 0 20px 6px rgba(56, 235, 97, 0.7);
        border-color: rgb(100, 255, 140);
      }
    }

    .action-button-glow {
      background: rgb(20, 60, 30);
      border: 2px solid rgb(56, 235, 97);
      color: rgb(56, 235, 97);
      font-weight: bold;
      animation: glow-green-pulse 1.8s ease-in-out infinite;
    }

    .action-button-glow:hover {
      background: rgb(30, 80, 40);
      color: rgb(100, 255, 140);
      border-color: rgb(100, 255, 140);
    }

    #name-modal {
      display: none;
    }

    #name-modal.visible {
      display: flex;
    }

    #post-save-box {
      display: none;
    }

    #post-save-box.visible {
      display: block;
      animation: slideIn 0.5s ease-out;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

