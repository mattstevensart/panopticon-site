          // Find matching button in desktop grid and click it
          let desktopBtn;
          if (itemPath) {
            desktopBtn = desktopItems.querySelector(`[data-item-path="${CSS.escape(itemPath)}"]`);
          }
          if (!desktopBtn && catIdx !== undefined) {
            desktopBtn = desktopItems.querySelector(`[data-category-idx="${catIdx}"]`);
          }
          if (desktopBtn) desktopBtn.click();
          // Sync after selection
          setTimeout(() => { syncMobileCanvas(); syncMobileItems(); }, 100);
        });
      });
    }

    function syncMobileCanvas() {
      const mCanvas = document.getElementById('mobile-canvas');
      const dCanvas = document.getElementById('preview-canvas');
      if (!mCanvas || !dCanvas) return;
      const mCtx = mCanvas.getContext('2d');
      mCanvas.width = dCanvas.width;
      mCanvas.height = dCanvas.height;
      mCtx.drawImage(dCanvas, 0, 0);
    }

    function setupMobileEvents() {
      // Mobile reset
      document.getElementById('mobile-reset-btn')?.addEventListener('click', () => {
        document.getElementById('reset-btn')?.click();
        setTimeout(() => { syncMobileCanvas(); syncMobileItems(); }, 200);
      });
      // Mobile name
      document.getElementById('mobile-name-btn')?.addEventListener('click', () => {
        document.getElementById('name-btn')?.click();
      });
      // Mobile ID
      document.getElementById('mobile-id-btn')?.addEventListener('click', () => {
        document.getElementById('id-btn')?.click();
        setTimeout(syncMobileCanvas, 500);
      });
      // Mobile save
      document.getElementById('mobile-save-btn')?.addEventListener('click', () => {
        document.getElementById('save-btn')?.click();
      });
    }

    function handleResize() {
      const viewport = document.getElementById('creator-viewport');
      const mobileView = document.getElementById('mobile-creator');
      if (!viewport) return;
      const screenWidth = window.innerWidth;

      const creatorMain = document.getElementById('creator-main');
      const desktopFrame = document.getElementById('desktop-concrete-frame');

      // Mobile breakpoint: use stacked layout
      if (screenWidth < 768 && mobileView) {
        if (creatorMain) creatorMain.style.display = 'none';
        mobileView.style.display = 'block';
        // Sync canvas to mobile
        const mCanvas = document.getElementById('mobile-canvas');
        const dCanvas = document.getElementById('preview-canvas');
        if (mCanvas && dCanvas) {
          const mCtx = mCanvas.getContext('2d');
          mCanvas.width = dCanvas.width;
          mCanvas.height = dCanvas.height;
          mCtx.drawImage(dCanvas, 0, 0);
        }
      } else {
        if (mobileView) mobileView.style.display = 'none';
        if (creatorMain) creatorMain.style.display = 'flex';
        const containerWidth = creatorMain ? creatorMain.clientWidth : window.innerWidth;
        const framePad = 36; // 18px concrete padding each side
        const targetWidth = 1280;
        const targetHeight = 840;
        const availableWidth = containerWidth - framePad - 32;
        if (availableWidth < targetWidth) {
          const scale = availableWidth / targetWidth;
          viewport.style.transform = `scale(${scale})`;
          viewport.style.height = (targetHeight * scale) + 'px';
          if (desktopFrame) desktopFrame.style.height = (targetHeight * scale + 64) + 'px';
        } else {
          viewport.style.transform = 'scale(1)';
          viewport.style.height = targetHeight + 'px';
          if (desktopFrame) desktopFrame.style.height = '';
        }
      }
    }

    function buildCategoryList() {
      const list = document.getElementById('category-list');
      list.innerHTML = '';
      CATEGORIES.forEach((cat, idx) => {
        const btn = document.createElement('button');
        btn.className = 'category-btn';
        btn.textContent = cat.name;
        btn.dataset.index = idx;
        btn.addEventListener('click', () => selectCategory(idx));
        list.appendChild(btn);
      });
      selectCategory(0);
    }

    function selectCategory(idx) {
      const buttons = document.querySelectorAll('.category-btn');
      buttons.forEach((b, i) => {
        const isActive = i === idx;
        b.classList.toggle('active', isActive);
        const cat = CATEGORIES[i];
        const isUnlocked = cat.unlockStage <= currentUnlockStage;
        b.classList.toggle('locked', !isUnlocked);
        b.classList.toggle('has-selection', !!selections[cat.folder]);
      });
      renderItemGrid(idx);
    }

    function renderItemGrid(catIdx) {
      const cat = CATEGORIES[catIdx];
      if (cat.unlockStage > currentUnlockStage) return;

      const gridArea = document.getElementById('item-grid-area');
      gridArea.innerHTML = '';

      let items = getItemsForCategory(cat);

      const gridDiv = document.createElement('div');
      gridDiv.className = 'item-grid';

      items.forEach(item => {
        const wrapper = document.createElement('div');
        wrapper.className = 'item-wrapper';

        const btn = document.createElement('button');
        btn.className = 'item-thumbnail';
        btn.dataset.categoryIdx = catIdx;
        btn.dataset.itemPath = item.full;
        btn.dataset.thumbPath = item.thumb;
        btn.dataset.label = item.label;

        const img = document.createElement('img');
        img.src = item.thumb;
        img.alt = item.label;
        img.loading = 'lazy';
        btn.appendChild(img);

        const isSelected = selections[cat.folder]?.full === item.full;
        if (isSelected) btn.classList.add('confirmed');

        btn.addEventListener('click', () => toggleSelection(catIdx, item));
        wrapper.appendChild(btn);

        // Only show labels for Gender category (MALE / FEMALE)
        if (cat.folder === 'clothing/') {
          const label = document.createElement('div');
          label.className = 'item-label';
          const isFemale = item.filename.toLowerCase().includes('female');
          label.textContent = isFemale ? 'FEMALE' : 'MALE';
          label.style.fontSize = '12px';
          label.style.fontFamily = 'Orbitron';
          label.style.fontWeight = 'bold';
          label.style.color = 'rgb(214, 214, 224)';
          wrapper.appendChild(label);
        }

        gridDiv.appendChild(wrapper);
      });

      // Add NONE option for all categories except Gender
      if (cat.folder !== 'clothing/') {
        const noneWrapper = document.createElement('div');
        noneWrapper.className = 'item-wrapper';
        const noneBtn = document.createElement('button');
        noneBtn.className = 'item-thumbnail';
        noneBtn.style.borderStyle = 'dashed';
        noneBtn.style.display = 'flex';
        noneBtn.style.alignItems = 'center';
        noneBtn.style.justifyContent = 'center';
        noneBtn.style.minHeight = '80px';
        noneBtn.innerHTML = '<span style="font-family: Electrolize; font-size: 12px; color: rgb(92, 87, 111);">NONE</span>';
        noneBtn.addEventListener('click', () => {
          selections[cat.folder] = null;
          renderCanvas();
          selectCategory(catIdx);
        });
        noneWrapper.appendChild(noneBtn);
        gridDiv.appendChild(noneWrapper);
      }

      gridArea.appendChild(gridDiv);
    }

    function encodePath(p) {
      return p.split('/').map(s => encodeURIComponent(s)).join('/');
    }

    function getItemsForCategory(cat) {
      let items = [];
      const manifest = ASSET_MANIFEST;
      const catFolder = cat.folder; // e.g. "clothing/", "heads/", "eyes/"

      manifest.forEach(path => {
        const webPath = path.replace(/^assets\//, '');

        // Strict startsWith match to avoid "eyes/" matching "female eyes/"
        if (webPath.startsWith(catFolder) || webPath.toLowerCase().startsWith(catFolder.toLowerCase())) {
          const parts = webPath.split('/');
          const filename = parts[parts.length - 1];
          const filenameNoExt = filename.replace('.png', '');

          const fullPath = encodePath('/avatar-assets/' + webPath);
          const thumbPath = encodePath('/avatar-assets/_thumbs/' + webPath);

          items.push({
            full: fullPath,
            thumb: thumbPath,
            label: filenameNoExt,
            filename: filename
          });
        }
      });

      // Ear color filtering — only show ears matching the selected head's skin color
      if (cat.folder === 'ears/' && selections['heads/']) {
        const headFilename = selections['heads/'].filename.toLowerCase().replace('.png', '');
        items = items.filter(item => {
          const earColor = item.filename.toLowerCase().replace('.png', '');
          return earColor === headFilename;
        });
      }

      // Female eyes merge into Eyes grid when female clothing selected
      if (cat.folder === 'eyes/' && selections['clothing/']?.filename.toLowerCase().includes('female')) {
        const femaleEyes = manifest.filter(p => p.startsWith('assets/female eyes/')).map(p => {
          const webPath = p.replace(/^assets\//, '');
          const parts = webPath.split('/');
          const filename = parts[parts.length - 1];
          const filenameNoExt = filename.replace('.png', '');
          return {
            full: encodePath('/avatar-assets/' + webPath),
            thumb: encodePath('/avatar-assets/_thumbs/' + webPath),
            label: filenameNoExt,
            filename: filename
          };
        });
        items = items.concat(femaleEyes);
      }

      // Female lips merge into Mouth grid when female clothing selected
      if (cat.folder === 'mouth/' && selections['clothing/']?.filename.toLowerCase().includes('female')) {
        const femaleLips = manifest.filter(p => p.startsWith('assets/female lips/')).map(p => {
          const webPath = p.replace(/^assets\//, '');
          const parts = webPath.split('/');
          const filename = parts[parts.length - 1];
          const filenameNoExt = filename.replace('.png', '');
          return {
            full: encodePath('/avatar-assets/' + webPath),
            thumb: encodePath('/avatar-assets/_thumbs/' + webPath),
            label: filenameNoExt,
            filename: filename
          };
        });
        items = items.concat(femaleLips);
      }

      return items;
    }

    function toggleSelection(catIdx, item) {
      const cat = CATEGORIES[catIdx];
      const folder = cat.folder;

      if (selections[folder]?.full === item.full) {
        selections[folder] = null;
      } else {
        selections[folder] = item;
        updateUnlockStage();
      }

      renderCanvas();
      selectCategory(catIdx);
    }

    function updateUnlockStage() {
      let faceFeatureCount = 0;
      const faceFeatures = ['eyes/', 'mouth/', 'noses/', 'eyebrows/'];
      faceFeatures.forEach(f => {
        if (selections[f]) faceFeatureCount++;
      });

      const genderSelected = !!selections['clothing/'];
      const headSelected = !!selections['heads/'];
      const hasHornsOrScars = !!selections['Horns/'] || !!selections['Scarz/'];

      if (genderSelected && headSelected) {
        if (faceFeatureCount >= 2) {
          if (hasHornsOrScars) {
            currentUnlockStage = 4;
          } else {
            currentUnlockStage = 3;
          }
        } else {
          currentUnlockStage = 2;
        }
      } else if (genderSelected) {
        currentUnlockStage = 1;
      } else {
        currentUnlockStage = 0;
      }

      // Show NAME INMATE when ALL categories have a selection
      const allSelected = CATEGORIES.every(cat => !!selections[cat.folder]);
      const nameBtn = document.getElementById('name-btn');
      if (nameBtn && !charName) {
        nameBtn.style.display = allSelected ? 'inline-block' : 'none';
      }

      // Sync mobile action buttons
      const mNameBtn = document.getElementById('mobile-name-btn');
      const mIdBtn = document.getElementById('mobile-id-btn');
      const mSaveBtn = document.getElementById('mobile-save-btn');
      if (mNameBtn) mNameBtn.style.display = document.getElementById('name-btn')?.style.display || 'none';
      if (mIdBtn) mIdBtn.style.display = document.getElementById('id-btn')?.style.display || 'none';
      if (mSaveBtn) mSaveBtn.style.display = document.getElementById('save-btn')?.style.display || 'none';

      // Sync mobile category locked/selection states
      const mobileCats = document.querySelectorAll('.mobile-cat-btn');
      mobileCats.forEach((btn, i) => {
        const cat = CATEGORIES[i];
        btn.classList.toggle('locked', cat.unlockStage > currentUnlockStage);
        btn.classList.toggle('has-selection', !!selections[cat.folder]);
      });
    }

    function initCanvas() {
      // Canvas is ready
    }

    async function renderCanvas() {
      const canvas = document.getElementById('preview-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      ctx.fillStyle = 'rgb(10, 10, 15)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Build layers sorted by drawOrder
      const layers = [];
      CATEGORIES.forEach(cat => {
        const sel = selections[cat.folder];
        if (sel) {
          layers.push({ order: cat.drawOrder, path: sel.full, catName: cat.name });
        }
      });
      layers.sort((a, b) => a.order - b.order);

      // Load all images first, then draw in order
      const loaded = await Promise.all(layers.map(async (layer) => {
        const img = await loadImage(layer.path);
        return { ...layer, img };
      }));

      // Draw HUD overlay
      const hudPath = encodePath('/avatar-assets/Intake HUD/HUD NEW.png');
      const hudImg = await loadImage(hudPath);
      let hudDrawn = false;

      for (const layer of loaded) {
        // Insert HUD before drawOrder 15 (Food)
        if (!hudDrawn && layer.order >= 15 && hudImg) {
          ctx.drawImage(hudImg, 0, 0, canvas.width, canvas.height);
          hudDrawn = true;
        }
        if (layer.img) {
          ctx.drawImage(layer.img, 0, 0, canvas.width, canvas.height);
        }
      }

      // If HUD hasn't been drawn yet (no layer with order >= 15), draw it on top
      if (!hudDrawn && hudImg) {
        ctx.drawImage(hudImg, 0, 0, canvas.width, canvas.height);
      }

      // Draw HUD text labels
      drawHudLabels(ctx);

      // Draw ID patch if generated
      if (idCode) {
        drawIdPatch(ctx, idCode);
      }

      // Sync to mobile canvas if visible
      syncMobileCanvas();
    }

    function drawHudLabels(ctx) {
      // HUD label positions (canvas coords from Godot: lx=27, lw=146, y centers at 71, 127, 183)
      const lx = 27, lw = 146;
      const labels = [];

      // Gender
      const genderSel = selections['clothing/'];
      if (genderSel) {
        const isFemale = genderSel.filename.toLowerCase().includes('female');
        labels.push({ text: isFemale ? 'FEMALE' : 'MALE', y: 71 });
      }

      // Race (head style name)
      const headSel = selections['heads/'];
      if (headSel) {
        const parts = headSel.full.split('/');
        const styleName = parts[parts.length - 2] || '';
        labels.push({ text: styleName.toUpperCase(), y: 127 });
      }

      // Nutri (food name)
      const foodSel = selections['Food/'];
      if (foodSel) {
        labels.push({ text: foodSel.label.toUpperCase(), y: 183 });
      }

      ctx.save();
      ctx.font = 'bold 13px Orbitron';
      ctx.fillStyle = 'rgb(217, 64, 255)';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      labels.forEach(l => {
        ctx.fillText(l.text, lx + lw / 2, l.y);
      });
      ctx.restore();
    }

    function drawIdPatch(ctx, code) {
      // Patch at chest position (Godot: PATCH_CX=462, PATCH_CY=596, PATCH_DISP=90)
      const cx = 462, cy = 596, r = 45;

      ctx.save();
      // Outer dark ring
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgb(28, 28, 32)';
      ctx.fill();

      // Dark outer border
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgb(12, 12, 15)';
      ctx.lineWidth = 8;
      ctx.stroke();

      // Light gray center
      ctx.beginPath();
      ctx.arc(cx, cy, r * 0.80, 0, Math.PI * 2);
      ctx.fillStyle = 'rgb(168, 168, 172)';
      ctx.fill();

      // Thin dark ring
      ctx.beginPath();
      ctx.arc(cx, cy, r * 0.80, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgb(85, 85, 92)';
      ctx.lineWidth = 2;
      ctx.stroke();

      // ID text
      ctx.font = 'bold ' + Math.round(r * 0.56) + 'px Orbitron';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      // Shadow
      ctx.fillStyle = 'rgba(30, 0, 50, 0.55)';
      ctx.fillText(code, cx + 1, cy + 1);
      // Main text
      ctx.fillStyle = 'rgb(100, 0, 140)';
      ctx.fillText(code, cx, cy);
      ctx.restore();
    }

    function loadImage(path) {
      return new Promise((resolve) => {
        if (imageCache[path]) {
          resolve(imageCache[path]);
          return;
        }
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.src = path;
        img.onload = () => {
          imageCache[path] = img;
          resolve(img);
        };
        img.onerror = () => resolve(null);
      });
    }

    function startIntro() {
      if (introCompleted) return;

      const overlay = document.getElementById('intro-overlay');
      const line1 = document.getElementById('intro-line-1');
      const line2 = document.getElementById('intro-line-2');
      const line3 = document.getElementById('intro-line-3');

      setTimeout(() => { line1.style.opacity = '1'; }, 1200);
      setTimeout(() => { line2.style.opacity = '1'; }, 3400);
      setTimeout(() => { line3.style.opacity = '1'; }, 5600);

      setTimeout(() => {
        overlay.style.opacity = '0';
        overlay.style.transition = 'opacity 0.5s';
        setTimeout(() => {
          overlay.style.display = 'none';
          introCompleted = true;
        }, 500);
      }, 8500);
    }

    function setupEventListeners() {
      document.getElementById('reset-btn').addEventListener('click', resetCreator);
      document.getElementById('name-btn').addEventListener('click', showNameModal);
      document.getElementById('name-cancel-btn').addEventListener('click', hideNameModal);
      document.getElementById('name-confirm-btn').addEventListener('click', confirmName);
      document.getElementById('name-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') confirmName();
      });
      document.getElementById('id-btn').addEventListener('click', generateId);
      document.getElementById('save-btn').addEventListener('click', savePng);
    }

    function resetCreator() {
      selections = {};
      charName = '';
      idCode = '';
      currentUnlockStage = 0;
      document.getElementById('name-btn').style.display = 'none';
      document.getElementById('id-btn').style.display = 'none';
      document.getElementById('save-btn').style.display = 'none';
      // Reset mobile buttons too
      const mNameBtn = document.getElementById('mobile-name-btn');
      const mIdBtn = document.getElementById('mobile-id-btn');
      const mSaveBtn = document.getElementById('mobile-save-btn');
      if (mNameBtn) mNameBtn.style.display = 'none';
      if (mIdBtn) mIdBtn.style.display = 'none';
      if (mSaveBtn) mSaveBtn.style.display = 'none';
      document.getElementById('post-save-box').classList.remove('visible');
      renderCanvas();
      buildCategoryList();
      buildMobileCategories();
      selectCategory(0);
    }

    function showNameModal() {
      document.getElementById('name-modal').classList.add('visible');
      document.getElementById('name-input').focus();
    }

    function hideNameModal() {
      document.getElementById('name-modal').classList.remove('visible');
      document.getElementById('name-input').value = '';
    }

    function confirmName() {
      const input = document.getElementById('name-input');
      const name = input.value.trim();
      if (!name) return;
      charName = name;
      hideNameModal();
      document.getElementById('name-btn').style.display = 'none';
      document.getElementById('id-btn').style.display = 'inline-block';
      // Sync mobile
      const mNameBtn = document.getElementById('mobile-name-btn');
      const mIdBtn = document.getElementById('mobile-id-btn');
      if (mNameBtn) mNameBtn.style.display = 'none';
      if (mIdBtn) mIdBtn.style.display = 'inline-block';
    }

    function generateId() {
      if (!charName) return;
      const letter = charName[0].toUpperCase();
      const num = Math.floor(Math.random() * 100);
      idCode = letter + String(num).padStart(2, '0');
      document.getElementById('id-btn').style.display = 'none';
      document.getElementById('save-btn').style.display = 'inline-block';
      // Sync mobile
      const mIdBtn = document.getElementById('mobile-id-btn');
      const mSaveBtn = document.getElementById('mobile-save-btn');
      if (mIdBtn) mIdBtn.style.display = 'none';
      if (mSaveBtn) mSaveBtn.style.display = 'inline-block';
      renderCanvas();
    }

    async function savePng() {
      // Camera flash
      const flash = document.createElement('div');
      flash.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:white;z-index:9999;opacity:0;transition:opacity 0.05s;';
      document.body.appendChild(flash);
      flash.offsetHeight; // force reflow
      flash.style.opacity = '1';
      setTimeout(() => { flash.style.opacity = '0'; }, 60);
      setTimeout(() => { flash.style.opacity = '0.85'; }, 140);
      setTimeout(() => { flash.style.opacity = '0'; }, 200);
      setTimeout(() => { flash.remove(); }, 500);

      // Compose at full resolution on offscreen canvas
      const exportSize = 4200;
      const offscreen = document.createElement('canvas');
      offscreen.width = exportSize;
      offscreen.height = exportSize;
      const ctx = offscreen.getContext('2d');

      // Build layers sorted by drawOrder
      const layers = [];
      CATEGORIES.forEach(cat => {
        const sel = selections[cat.folder];
        if (sel) layers.push({ order: cat.drawOrder, path: sel.full });
      });
      layers.sort((a, b) => a.order - b.order);

      const loaded = await Promise.all(layers.map(async (l) => ({
        ...l, img: await loadImage(l.path)
      })));

      const hudImg = await loadImage(encodePath('/avatar-assets/Intake HUD/HUD NEW.png'));
      let hudDrawn = false;

      for (const layer of loaded) {
        if (!hudDrawn && layer.order >= 15 && hudImg) {
          ctx.drawImage(hudImg, 0, 0, exportSize, exportSize);
          hudDrawn = true;
        }
        if (layer.img) ctx.drawImage(layer.img, 0, 0, exportSize, exportSize);
      }
      if (!hudDrawn && hudImg) ctx.drawImage(hudImg, 0, 0, exportSize, exportSize);

      // Draw HUD labels at export scale
      const scale = exportSize / 700;
      ctx.save();
      ctx.font = 'bold ' + Math.round(13 * scale) + 'px Orbitron';
      ctx.fillStyle = 'rgb(217, 64, 255)';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      const genderSel = selections['clothing/'];
      if (genderSel) {
        const isFemale = genderSel.filename.toLowerCase().includes('female');
        ctx.fillText(isFemale ? 'FEMALE' : 'MALE', (27 + 73) * scale, 71 * scale);
      }
      const headSel = selections['heads/'];
      if (headSel) {
        const parts = headSel.full.split('/');
        ctx.fillText((parts[parts.length - 2] || '').toUpperCase(), (27 + 73) * scale, 127 * scale);
      }
      const foodSel = selections['Food/'];
      if (foodSel) {
        ctx.fillText(foodSel.label.toUpperCase(), (27 + 73) * scale, 183 * scale);
      }
      ctx.restore();

      // Draw ID patch at export scale
      if (idCode) {
        const cx = 462 * scale, cy = 596 * scale, r = 45 * scale;
        ctx.save();
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgb(28, 28, 32)'; ctx.fill();
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgb(12, 12, 15)'; ctx.lineWidth = 8 * scale; ctx.stroke();
        ctx.beginPath(); ctx.arc(cx, cy, r * 0.80, 0, Math.PI * 2);
        ctx.fillStyle = 'rgb(168, 168, 172)'; ctx.fill();
        ctx.beginPath(); ctx.arc(cx, cy, r * 0.80, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgb(85, 85, 92)'; ctx.lineWidth = 2 * scale; ctx.stroke();
        ctx.font = 'bold ' + Math.round(r * 0.56) + 'px Orbitron';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillStyle = 'rgba(30, 0, 50, 0.55)'; ctx.fillText(idCode, cx + 2, cy + 2);
        ctx.fillStyle = 'rgb(100, 0, 140)'; ctx.fillText(idCode, cx, cy);
        ctx.restore();
      }

      // Export as square (canvas is now 700×700, source art is 4200×4200)
      const cropped = offscreen; // No cropping needed — already square
      const cctx = ctx;

      // LSB Steganography — encode JSON into red-channel LSBs
      const tok = Array.from({length: 8}, () => 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'[Math.floor(Math.random() * 36)]).join('');
      const payload = JSON.stringify({
        name: charName,
        id: idCode.toUpperCase(),
        build: 'PANOPTICON',
        v: '1',
        tok: tok
      }) + '|||END|||';

      const imgData = cctx.getImageData(0, 0, cropped.width, cropped.height);
      const bytes = new TextEncoder().encode(payload);
      let bitIdx = 0;
      const totalBits = bytes.length * 8;
      for (let i = 0; i < imgData.data.length && bitIdx < totalBits; i += 4) {
        const byteVal = bytes[Math.floor(bitIdx / 8)];
        const bit = (byteVal >> (7 - (bitIdx % 8))) & 1;
        imgData.data[i] = (imgData.data[i] & 0xFE) | bit; // red channel LSB
        bitIdx++;
      }
      cctx.putImageData(imgData, 0, 0);

      // Download — use different approach for mobile vs desktop
      cropped.toBlob((blob) => {
        const safeName = charName.replace(/\s+/g, '_').replace(/[\/:\\]/g, '-');
        const filename = `${safeName}${idCode.toUpperCase()}.png`;

        if (window.innerWidth < 768) {
          // Mobile: open image in new tab so user can long-press to save to photos
          const url = URL.createObjectURL(blob);
          const newTab = window.open('', '_blank');
          if (newTab) {
            newTab.document.write(`<!DOCTYPE html><html><head><title>${filename}</title><meta name="viewport" content="width=device-width,initial-scale=1"><style>body{margin:0;background:#0a0a0f;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif;}</style></head><body><p style="color:#d6d6e0;font-size:14px;margin-bottom:12px;text-align:center;">Long-press the image to save to Photos</p><img src="${url}" style="max-width:95vw;max-height:80vh;" alt="${filename}"/></body></html>`);
            newTab.document.close();
          } else {
            // Fallback if popup blocked
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            a.click();
            URL.revokeObjectURL(url);
          }
        } else {
          // Desktop: standard download
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = filename;
          a.click();
          URL.revokeObjectURL(url);
        }
        showPostSaveMessage();
      }, 'image/png');
    }

    function showPostSaveMessage() {
      const box = document.getElementById('post-save-box');
      const text = document.getElementById('post-save-text');
      text.textContent = `INMATE INTAKE COMPLETE.\nYOU ARE INMATE ${charName.toUpperCase()}. ID #${idCode}.\nWELCOME TO THE PANOPTICON.\nSURVEILLANCE IS MANDATORY.`;
      box.classList.add('visible');
      localStorage.setItem('panopticon_intake_complete', 'true');

      // Store full inmate profile for header display
      const genderSel = selections['clothing/'];
      const headSel = selections['heads/'];
      const foodSel = selections['Food/'];
      const isFemale = genderSel?.filename?.toLowerCase().includes('female');
      const raceParts = headSel?.full?.split('/') || [];
      const raceName = raceParts[raceParts.length - 2] || '—';

      localStorage.setItem('panopticon_inmate_name', charName.toUpperCase());
      localStorage.setItem('panopticon_inmate_id', idCode.toUpperCase());
      localStorage.setItem('panopticon_inmate_gender', isFemale ? 'FEMALE' : 'MALE');
      localStorage.setItem('panopticon_inmate_race', raceName.toUpperCase());
      localStorage.setItem('panopticon_inmate_nutri', foodSel ? foodSel.label.toUpperCase() : '—');

      // Store avatar preview thumb
      try {
        const canvas = document.getElementById('preview-canvas');
        const thumbCanvas = document.createElement('canvas');
        thumbCanvas.width = 240;
        thumbCanvas.height = 240;
        const tCtx = thumbCanvas.getContext('2d');
        tCtx.imageSmoothingEnabled = true;
        tCtx.imageSmoothingQuality = 'high';
        tCtx.drawImage(canvas, 0, 0, 240, 240);
        localStorage.setItem('panopticon_avatar_thumb', thumbCanvas.toDataURL('image/png'));
      } catch(e) {}
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</Layout>
