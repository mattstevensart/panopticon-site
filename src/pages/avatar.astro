    function mobileFallbackSave(blob, filename) {
      // Convert blob to data URL and open in new tab for long-press save
      const reader = new FileReader();
      reader.onload = () => {
        const dataUrl = reader.result;
        const newTab = window.open('', '_blank');
        if (newTab) {
          newTab.document.write(`<!DOCTYPE html><html><head><title>${filename}</title><meta name="viewport" content="width=device-width,initial-scale=1"><style>body{margin:0;background:#0a0a0f;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif;}</style></head><body><p style="color:#d6d6e0;font-size:14px;margin-bottom:12px;text-align:center;">Long-press the image to save to Photos</p><img src="${dataUrl}" style="max-width:95vw;max-height:80vh;" alt="${filename}"/></body></html>`);
          newTab.document.close();
        } else {
          // If popup blocked, use download link
          const a = document.createElement('a');
          a.href = dataUrl;
          a.download = filename;
          a.click();
        }
      };
      reader.readAsDataURL(blob);
    }

    async function savePng() {
      // Stop glow on Save PNG button after click
      const saveEl = document.getElementById('save-btn');
      if (saveEl) { saveEl.classList.add('glow-done'); saveEl.textContent = '✓ SAVED'; }
      const mSaveEl = document.getElementById('mobile-save-btn');
      if (mSaveEl) { mSaveEl.classList.add('glow-done'); mSaveEl.textContent = '✓ SAVED'; }

      // Store avatar thumbnail EARLY so Firebase registration gets the current one
      try {
        const canvas = document.getElementById('preview-canvas');
        const thumbCanvas = document.createElement('canvas');
        thumbCanvas.width = 240;
        thumbCanvas.height = 240;
        const tCtx = thumbCanvas.getContext('2d');
        tCtx.drawImage(canvas, 0, 0, 240, 240);
        localStorage.setItem('panopticon_avatar_thumb', thumbCanvas.toDataURL('image/png'));
      } catch(e) { /* thumbnail generation failed, non-critical */ }

      // Camera flash
      const flash = document.createElement('div');
      flash.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:white;z-index:9999;opacity:0;transition:opacity 0.05s;';
      document.body.appendChild(flash);
      flash.offsetHeight; // force reflow
      flash.style.opacity = '1';
      setTimeout(() => { flash.style.opacity = '0'; }, 60);
      setTimeout(() => { flash.style.opacity = '0.85'; }, 140);
      setTimeout(() => { flash.style.opacity = '0'; }, 200);
      setTimeout(() => { flash.remove(); }, 500);

      // Compose at full resolution on offscreen canvas
      // iOS Safari has canvas memory limits — use smaller export on mobile
      const isMobile = window.innerWidth < 768;
      const exportSize = isMobile ? 2100 : 4200;
      const offscreen = document.createElement('canvas');
      offscreen.width = exportSize;
      offscreen.height = exportSize;
      const ctx = offscreen.getContext('2d');

      // Build layers sorted by drawOrder
      const layers = [];
      CATEGORIES.forEach(cat => {
        const sel = selections[cat.folder];
        if (sel && sel !== '__none__') layers.push({ order: cat.drawOrder, path: sel.full });
      });
      layers.sort((a, b) => a.order - b.order);

      const loaded = await Promise.all(layers.map(async (l) => ({
        ...l, img: await loadImage(l.path)
      })));

      const hudImg = await loadImage(encodePath('/avatar-assets/Intake HUD/HUD NEW.png'));
      let hudDrawn = false;

      for (const layer of loaded) {
        if (!hudDrawn && layer.order >= 15 && hudImg) {
          ctx.drawImage(hudImg, 0, 0, exportSize, exportSize);
          hudDrawn = true;
        }
        if (layer.img) ctx.drawImage(layer.img, 0, 0, exportSize, exportSize);
      }
      if (!hudDrawn && hudImg) ctx.drawImage(hudImg, 0, 0, exportSize, exportSize);

      // Draw HUD labels at export scale
      const scale = exportSize / 700;
      ctx.save();
      ctx.font = 'bold ' + Math.round(13 * scale) + 'px Orbitron';
      ctx.fillStyle = 'rgb(217, 64, 255)';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      const genderSel = selections['clothing/'];
      if (genderSel) {
        const isFemale = genderSel.filename.toLowerCase().includes('female');
        ctx.fillText(isFemale ? 'FEMALE' : 'MALE', (27 + 73) * scale, 71 * scale);
      }
      const headSel = selections['heads/'];
      if (headSel) {
        const parts = headSel.full.split('/');
        const raceName = (parts[parts.length - 2] || '').replace(/_female$/i, '');
        ctx.fillText(raceName.toUpperCase(), (27 + 73) * scale, 127 * scale);
      }
      const foodSel = selections['Food/'];
      if (foodSel && foodSel !== '__none__') {
        ctx.fillText(foodSel.label.toUpperCase(), (27 + 73) * scale, 183 * scale);
      }
      ctx.restore();

      // Draw ID patch at export scale
      if (idCode) {
        const cx = 462 * scale, cy = 596 * scale, r = 45 * scale;
        ctx.save();
        // Drop shadow (tight)
        ctx.beginPath(); ctx.arc(cx + 1.5 * scale, cy + 2 * scale, r + 1 * scale, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
        ctx.filter = 'blur(' + (2 * scale) + 'px)';
        ctx.fill();
        ctx.filter = 'none';
        // Outer dark ring
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgb(28, 28, 32)'; ctx.fill();
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgb(12, 12, 15)'; ctx.lineWidth = 8 * scale; ctx.stroke();
        ctx.beginPath(); ctx.arc(cx, cy, r * 0.80, 0, Math.PI * 2);
        ctx.fillStyle = 'rgb(168, 168, 172)'; ctx.fill();
        ctx.beginPath(); ctx.arc(cx, cy, r * 0.80, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgb(85, 85, 92)'; ctx.lineWidth = 2 * scale; ctx.stroke();
        ctx.font = 'bold ' + Math.round(r * 0.56) + 'px Orbitron';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillStyle = 'rgba(30, 0, 50, 0.55)'; ctx.fillText(idCode, cx + 2, cy + 2);
        ctx.fillStyle = 'rgb(100, 0, 140)'; ctx.fillText(idCode, cx, cy);
        ctx.restore();
      }

      // Export as square (canvas is now 700×700, source art is 4200×4200)
      const cropped = offscreen; // No cropping needed — already square
      const cctx = ctx;

      // LSB Steganography — encode JSON into red-channel LSBs
      // v2: Each data bit is written to REDUNDANCY consecutive pixels.
      //     The scanner uses majority voting to recover the correct bit,
      //     making the encoding resistant to compression artifacts on
      //     Samsung/mobile browsers that corrupt single-bit LSB values.
      const REDUNDANCY = 5;
      const tok = Array.from({length: 8}, () => 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'[Math.floor(Math.random() * 36)]).join('');
      const payload = JSON.stringify({
        name: charName,
        id: idCode.toUpperCase(),
        build: 'PANOPTICON',
        v: '2',
        tok: tok
      }) + '|||END|||';

      const imgData = cctx.getImageData(0, 0, cropped.width, cropped.height);
      const bytes = new TextEncoder().encode(payload);
      let bitIdx = 0;
      const totalBits = bytes.length * 8;
      let pixelIdx = 0;
      for (let b = 0; b < totalBits; b++) {
        const byteVal = bytes[Math.floor(b / 8)];
        const bit = (byteVal >> (7 - (b % 8))) & 1;
        // Write same bit to REDUNDANCY consecutive pixels
        for (let r = 0; r < REDUNDANCY; r++) {
          const i = pixelIdx * 4; // RGBA index
          if (i >= imgData.data.length) break;
          imgData.data[i] = (imgData.data[i] & 0xFE) | bit; // red channel LSB
          pixelIdx++;
        }
      }
      cctx.putImageData(imgData, 0, 0);

      // Download — try direct download first (preserves PNG losslessly),
      // fall back to Web Share API, then fallback save
      const blob = await new Promise(resolve => cropped.toBlob(resolve, 'image/png'));
      const safeName = charName.replace(/\s+/g, '_').replace(/[\/:\\]/g, '-');
      const filename = `${safeName}${idCode.toUpperCase()}.png`;

      // Store PNG data URL for auto-scan on the scanner page
      try {
        const reader = new FileReader();
        reader.onload = () => { localStorage.setItem('panopticon_autoscan_data', reader.result); };
        reader.readAsDataURL(blob);
      } catch(e) {}

      // Save medium-res avatar to Firestore (no Storage needed — free tier)
      // 800×800 is plenty for a printed grid in the back of the comic
      if (fbReady) {
        (async () => {
          try {
            const medCanvas = document.createElement('canvas');
            medCanvas.width = 800;
            medCanvas.height = 800;
            const medCtx = medCanvas.getContext('2d');
            medCtx.drawImage(cropped, 0, 0, 800, 800);
            const medDataUrl = medCanvas.toDataURL('image/png');
            const { collection, addDoc } = fbDb;
            await addDoc(collection(fbDb.fs, 'avatar_uploads'), {
              name: charName?.toUpperCase() || '',
              inmateId: idCode?.toUpperCase() || '',
              token: tok,
              filename: filename,
              imageData: medDataUrl,
              uploadedAt: new Date().toISOString(),
            });
            console.log('✅ Avatar saved to Firestore');
          } catch(e) { console.warn('Avatar save failed (non-critical):', e); }
        })();
      }

      if (isMobile) {
        // Mobile: try direct <a download> first — most Android browsers support it
        // and it preserves the PNG losslessly unlike Web Share API
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);

        // After a short delay, also offer Web Share as secondary option
        // (in case <a download> was blocked by the browser)
        setTimeout(async () => {
          if (navigator.share && navigator.canShare) {
            const file = new File([blob], filename, { type: 'image/png' });
            if (navigator.canShare({ files: [file] })) {
              try {
                await navigator.share({ files: [file], title: filename });
              } catch(e) { /* User cancelled — fine */ }
            }
          }
          URL.revokeObjectURL(url);
        }, 1500);
      } else {
        // Desktop: standard download
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.click();
        URL.revokeObjectURL(url);
      }
      showEmailModal();
    }

    function showEmailModal() {
      const modal = document.getElementById('email-modal');
      const input = document.getElementById('email-input');
      const submitBtn = document.getElementById('email-submit-btn');
      const errorEl = document.getElementById('email-error');
      const successEl = document.getElementById('email-success');
      const skipBtn = document.getElementById('email-skip-btn');

      modal.style.display = 'flex';
      input.value = '';
      errorEl.style.display = 'none';
      successEl.style.display = 'none';
      submitBtn.disabled = false;
      submitBtn.textContent = 'COUNT ME IN →';
      submitBtn.style.display = '';
      input.style.display = '';
      if (skipBtn) skipBtn.style.display = 'block';

      // Focus input after animation
      setTimeout(() => input.focus(), 100);

      // Enter key submits
      input.onkeydown = (e) => { if (e.key === 'Enter') submitBtn.click(); };

      // Focus styling
      input.onfocus = () => { input.style.borderColor = 'rgb(140, 64, 255)'; };
      input.onblur = () => { input.style.borderColor = 'rgb(92, 87, 111)'; };

      // Skip button — show warning first, then allow skip on second click
      let skipConfirmed = false;
      if (skipBtn) {
        skipBtn.onmouseenter = () => { skipBtn.style.color = 'rgb(214, 214, 224)'; };
        skipBtn.onmouseleave = () => { if (!skipConfirmed) skipBtn.style.color = 'rgb(92, 87, 111)'; };
        skipBtn.onclick = () => {
          if (!skipConfirmed) {
            skipConfirmed = true;
            skipBtn.textContent = 'SKIP — YOU CAN ALWAYS COME BACK AND ADD IT LATER';
            skipBtn.style.color = 'rgb(92, 87, 111)';
            return;
          }
          modal.style.display = 'none';
          showPostSaveMessage();
        };
