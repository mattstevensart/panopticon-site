          setTimeout(() => {
            modal.style.display = 'none';
            showPostSaveMessage();
          }, 1800);

        } catch(err) {
          // If Kit API fails, still register in Firebase and let them through
          console.warn('Kit subscription error:', err);
          localStorage.setItem('panopticon_inmate_email', email);
          const thumbData2 = localStorage.getItem('panopticon_avatar_thumb') || '';
          const tokVal2 = localStorage.getItem('panopticon_inmate_tok') || idCode || '';
          registerInFirebase(email, charName?.toUpperCase(), idCode?.toUpperCase(), tokVal2, thumbData2);
          successEl.textContent = 'SIGNAL RECEIVED. YOU\'RE IN.';
          successEl.style.display = 'block';
          submitBtn.style.display = 'none';
          input.style.display = 'none';
