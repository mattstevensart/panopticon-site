---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HOME">

  <!-- Fullscreen background watermark -->
  <div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 flex items-center justify-center">
      <img
        src="/images/read/webtoon-28.jpg"
        alt=""
        class="w-full h-full object-cover"
        style="mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.25) 100%), radial-gradient(ellipse 70% 70% at center, black 30%, transparent 80%); -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.25) 100%), radial-gradient(ellipse 70% 70% at center, black 30%, transparent 80%); mask-composite: intersect; -webkit-mask-composite: source-in;"
      />
    </div>
  </div>

  <!-- Hero -->
  <section class="relative min-h-[75vh] flex flex-col items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-grid-subtle bg-grid opacity-100 pointer-events-none"></div>
    <div class="absolute inset-0 bg-scanline opacity-40 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-p-accent/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center text-center px-4 gap-8">
      <div class="relative">
        <img src="/images/panopticon-title.png" alt="PANOPTICON" class="w-full max-w-lg md:max-w-2xl opacity-95" />
        <div class="absolute top-4 left-1/2 -translate-x-1/2 w-6 h-6 rounded-full bg-p-red/30 blur-lg animate-pulse"></div>
      </div>

      <div class="space-y-2">
        <p class="font-display text-p-text text-lg md:text-2xl tracking-wide">Welcome to the Panopticon | 63rd.</p>
        <p class="font-ui text-p-teal text-sm tracking-[0.3em]">Surveillance is mandatory.</p>
      </div>

      <div class="flex flex-col items-center gap-1 text-xs font-ui mt-8 animate-pulse-unlock-text" style="color: rgb(140, 64, 255);">
        <span class="tracking-widest">SCROLL</span>
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="relative z-10 max-w-6xl mx-auto px-4 py-10">
    <div class="text-center mb-12">
      <h2 class="font-display text-2xl md:text-3xl text-p-text tracking-wide">INDOCTRINATION</h2>
      <div class="w-24 h-px bg-p-accent mx-auto mt-4"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <a href="/avatar" class="group border border-p-teal/20 hover:border-p-teal/60 p-6 transition-all hover:shadow-teal-glow" style="background: rgba(23, 23, 33, 0.75);">
        <div class="text-p-teal text-3xl mb-4 font-display">01</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">INTAKE PROCESSING</h3>
        <p class="font-comic text-p-dim text-sm leading-relaxed">Build your inmate avatar. Every prisoner must be processed and catalogued.</p>
        <p class="font-ui text-p-teal text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">PROCESS →</p>
      </a>
      <a href="/read" class="group border border-p-accent/20 hover:border-p-accent/60 p-6 transition-all hover:shadow-accent-glow" style="background: rgba(23, 23, 33, 0.75);">
        <div class="text-p-accent text-3xl mb-4 font-display">02</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">THE COMIC</h3>
        <p class="font-comic text-p-dim text-sm leading-relaxed">Read excerpts from Act 1 and see sneak peeks from Act 2.</p>
        <p class="font-ui text-p-accent text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">READ →</p>
      </a>
      <a href="/earlybird" class="group border border-[#f59e0b]/20 hover:border-[#f59e0b]/60 p-6 transition-all" style="background: rgba(23, 23, 33, 0.75); box-shadow: 0 0 12px 2px rgba(245,158,11,0) ; transition: box-shadow 0.3s;" onmouseenter="this.style.boxShadow='0 0 16px 4px rgba(245,158,11,0.35)'" onmouseleave="this.style.boxShadow='none'">
        <div class="text-[#f59e0b] text-3xl mb-4 font-display">03</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">KICKSTARTER HQ</h3>
        <p class="font-comic text-p-dim text-sm leading-relaxed">Register for early bird perks, back the campaign, and enter the character lottery.</p>
        <p class="font-ui text-[#f59e0b] text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">REGISTER →</p>
      </a>
      <a id="classified-card" href="/avatar" class="group border border-p-unlock/20 hover:border-p-unlock/60 p-6 transition-all hover:shadow-unlock-glow opacity-70 hover:opacity-100" style="background: rgba(23, 23, 33, 0.75);">
        <div class="text-p-unlock text-3xl mb-4 font-display">04</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">CLASSIFIED FILES</h3>
        <p id="classified-body" class="font-comic text-p-dim text-sm leading-relaxed">Complete your intake to unlock a restricted-access section of the facility.</p>
        <p id="classified-cta" class="font-ui text-p-unlock text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">LOCKED →</p>
      </a>
    </div>
  </section>


</Layout>

<script>
  const isComplete = localStorage.getItem('panopticon_intake_complete') === 'true';
  if (isComplete) {
    const card = document.getElementById('classified-card');
    const body = document.getElementById('classified-body');
    const cta = document.getElementById('classified-cta');
    if (card) {
      card.href = '/unlocked';
      card.style.opacity = '1';
      card.classList.remove('border-p-unlock/20', 'hover:border-p-unlock/60');
      card.style.borderColor = 'rgba(140, 64, 255, 0.5)';
    }
    if (body) body.textContent = 'Intake confirmed. Access the restricted-access section of the facility.';
    if (cta) { cta.textContent = 'OPEN FILES →'; cta.style.color = 'rgb(140, 64, 255)'; }
  }
</script>
