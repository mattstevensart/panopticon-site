---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HOME">

  <!-- Hero -->
  <section class="relative min-h-[90vh] flex flex-col items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-grid-subtle bg-grid opacity-100 pointer-events-none"></div>
    <div class="absolute inset-0 bg-scanline opacity-40 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-p-accent/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center text-center px-4 gap-8">
      <div class="relative">
        <img src="/images/panopticon-title.png" alt="PANOPTICON" class="w-full max-w-lg md:max-w-2xl opacity-95" />
        <div class="absolute top-4 left-1/2 -translate-x-1/2 w-6 h-6 rounded-full bg-p-red/30 blur-lg animate-pulse"></div>
      </div>

      <div class="space-y-2">
        <p class="font-display text-p-text text-lg md:text-2xl tracking-wide">Welcome to the Panopticon | 63rd.</p>
        <p class="font-ui text-p-teal text-sm tracking-[0.3em]">Surveillance is mandatory.</p>
      </div>

      <div class="flex flex-col items-center gap-1 text-p-dim/40 text-xs font-ui mt-8">
        <span class="tracking-widest">SCROLL</span>
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-2xl md:text-3xl text-p-text tracking-wide">WHAT AWAITS YOU</h2>
      <div class="w-24 h-px bg-p-accent mx-auto mt-4"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/avatar" class="group bg-p-panel border border-p-teal/20 hover:border-p-teal/60 p-6 transition-all hover:shadow-teal-glow">
        <div class="text-p-teal text-3xl mb-4 font-display">01</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">INTAKE PROCESSING</h3>
        <p class="font-comic text-p-dim text-sm leading-relaxed">Build your inmate avatar. Every prisoner must be processed and catalogued.</p>
        <p class="font-ui text-p-teal text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">PROCESS →</p>
      </a>
      <a href="/read" class="group bg-p-panel border border-p-accent/20 hover:border-p-accent/60 p-6 transition-all hover:shadow-accent-glow">
        <div class="text-p-accent text-3xl mb-4 font-display">02</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">THE COMIC</h3>
        <p class="font-comic text-p-dim text-sm leading-relaxed">Read excerpts from Act 1 and see sneak peeks from Act 2.</p>
        <p class="font-ui text-p-accent text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">READ →</p>
      </a>
      <a href="/avatar" class="group bg-p-panel border border-p-unlock/20 hover:border-p-unlock/60 p-6 transition-all hover:shadow-unlock-glow opacity-70 hover:opacity-100">
        <div class="text-p-unlock text-3xl mb-4 font-display">??</div>
        <h3 class="font-display text-sm tracking-widest text-p-text mb-2">CLASSIFIED FILE</h3>
        <p class="font-comic text-p-dim text-sm leading-relaxed">Complete your intake to unlock a restricted-access section of the facility.</p>
        <p class="font-ui text-p-unlock text-xs tracking-widest mt-4 group-hover:tracking-[0.3em] transition-all">LOCKED →</p>
      </a>
    </div>
  </section>


</Layout>
